<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Tren – Settings</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;height:100%;background:#04080f;overflow:hidden;}
:root{
  --bg:#04080f;--bg2:#080e1a;--bg3:#0c1525;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);
  --accent:#2563eb;--al:#3b82f6;--green:#10b981;--red:#ef4444;--gold:#f59e0b;
  --text:#f0f4ff;--sub:rgba(240,244,255,0.45);--sub2:rgba(240,244,255,0.72);
  --sw:220px;
}
.shell{position:fixed;inset:0;display:flex;font-family:'Plus Jakarta Sans',sans-serif;color:var(--text);background:var(--bg);}

/* ── SIDEBAR ── */
.sidebar{width:var(--sw);min-width:var(--sw);height:100vh;border-right:1px solid var(--border);background:#060b14;display:flex;flex-direction:column;padding:0;position:relative;z-index:20;overflow-y:auto;overflow-x:hidden;scrollbar-width:none;}
.sidebar::-webkit-scrollbar{display:none;}
.s-logo{font-size:17px;font-weight:600;padding:22px 18px 18px;display:flex;align-items:center;gap:9px;text-decoration:none;color:inherit;letter-spacing:-0.4px;}
.s-logo-dot{width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:0 0 0 3px rgba(37,99,235,0.2);flex-shrink:0;}
.s-logo span{color:var(--al);}
.s-section-label{font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(240,244,255,0.18);padding:12px 18px 4px;}
.s-nav{flex:1;display:flex;flex-direction:column;padding:0 10px;gap:1px;}
.s-item{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;font-size:13px;font-weight:500;color:rgba(240,244,255,0.42);cursor:pointer;transition:background .12s,color .12s;text-decoration:none;position:relative;}
.s-item:hover{background:rgba(255,255,255,.04);color:rgba(240,244,255,0.8);}
.s-item.on{background:rgba(37,99,235,.14);color:#e0eaff;}
.s-item.on::before{content:'';position:absolute;left:-6px;top:50%;transform:translateY(-50%);width:3px;height:16px;border-radius:0 3px 3px 0;background:var(--accent);}
.s-item.gold{color:var(--gold);}
.s-item.gold:hover{background:rgba(245,158,11,.06);}
.s-item.ai-item{color:#a78bfa;}
.s-item.ai-item:hover{background:rgba(167,139,250,.07);color:#c4b5fd;}
.s-ic{width:28px;height:28px;border-radius:7px;background:rgba(255,255,255,.04);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:13px;}
.s-item.on .s-ic{background:rgba(37,99,235,.18);}
.s-item.gold .s-ic{background:rgba(245,158,11,.08);}
.s-item.ai-item .s-ic{background:rgba(167,139,250,.1);}
.s-badge{margin-left:auto;font-size:9px;padding:2px 6px;border-radius:4px;font-weight:700;background:var(--gold);color:#000;letter-spacing:.03em;}
.s-beta{margin-left:auto;font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;background:rgba(167,139,250,.15);border:0.5px solid rgba(167,139,250,.3);color:#a78bfa;letter-spacing:.03em;}
.s-divider{height:0.5px;background:rgba(255,255,255,.05);margin:4px 10px;}
.s-bot{padding:10px 10px 14px;flex-shrink:0;border-top:0.5px solid rgba(255,255,255,.05);margin-top:auto;}
.trial-card{display:none;}
.up-mini{width:100%;padding:8px;border:none;border-radius:7px;background:linear-gradient(90deg,var(--accent),var(--al));color:#fff;font-size:11.5px;font-weight:600;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;transition:opacity .15s;}
.up-mini:hover{opacity:.88;}
.u-row{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:9px;cursor:pointer;transition:background .12s;text-decoration:none;border:0.5px solid transparent;}
.u-row:hover{background:rgba(255,255,255,.04);border-color:rgba(255,255,255,.07);}
.u-av{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,var(--accent),var(--al));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;flex-shrink:0;color:#fff;}
.u-info{min-width:0;flex:1;display:flex;flex-direction:column;gap:1px;}
.u-name{font-size:12.5px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.u-email{font-size:10px;color:var(--sub);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sub-status-badge{display:inline-flex;align-items:center;gap:3px;font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;margin-top:3px;letter-spacing:.03em;}
.sub-status-badge.trial{background:rgba(245,158,11,.1);border:0.5px solid rgba(245,158,11,.22);color:var(--gold);}
.sub-status-badge.premium{background:rgba(37,99,235,.12);border:0.5px solid rgba(37,99,235,.28);color:var(--al);}
.sub-status-badge.automated{background:rgba(245,158,11,.1);border:0.5px solid rgba(245,158,11,.22);color:var(--gold);}
.sub-status-badge.autosignals{background:rgba(16,185,129,.12);border:0.5px solid rgba(16,185,129,.28);color:var(--green);}
.s-logout{display:flex;align-items:center;gap:8px;padding:6px 10px;border-radius:7px;font-size:11.5px;font-weight:500;color:rgba(239,68,68,.45);cursor:pointer;transition:all .12s;margin-top:2px;}
.s-logout:hover{background:rgba(239,68,68,.07);color:var(--red);}
.live-dot-nav{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--green);animation:flicker 3.5s infinite;box-shadow:0 0 5px var(--green);}
@keyframes flicker{0%,100%{opacity:1;transform:scale(1);}15%{opacity:.88;transform:scale(.95);}30%{opacity:1;transform:scale(1.03);}45%{opacity:.92;transform:scale(.97);}60%{opacity:1;transform:scale(1.06);}75%{opacity:.9;transform:scale(.94);}90%{opacity:1;transform:scale(1.02);}}

/* ── MAIN ── */
.main-wrap{flex:1;display:flex;flex-direction:column;min-width:0;height:100vh;overflow:hidden;}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:1.1rem 2.4rem;border-bottom:1px solid var(--border);background:rgba(4,8,15,.88);backdrop-filter:blur(20px);flex-shrink:0;position:relative;z-index:10;}
.tb-title{font-size:17px;font-weight:700;}
.tb-right{display:flex;align-items:center;gap:11px;}
.t-pill{display:flex;align-items:center;gap:5px;background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.25);color:var(--gold);font-size:11.5px;font-weight:600;padding:5px 13px;border-radius:20px;}
.t-pill.premium{background:rgba(37,99,235,.12);border-color:rgba(37,99,235,.3);color:var(--al);}
.t-pill.autosignals{background:rgba(16,185,129,.12);border-color:rgba(16,185,129,.3);color:var(--green);}
.t-pill.automated{background:rgba(245,158,11,.12);border-color:rgba(245,158,11,.3);color:var(--gold);}
.nb{width:33px;height:33px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px;transition:border-color .2s;}
.nb:hover{border-color:var(--border2);}
.prof-wrap{position:relative;}
.prof-av{width:33px;height:33px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--al));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;cursor:pointer;border:2px solid transparent;transition:border-color .2s;color:#fff;}
.prof-av:hover{border-color:rgba(255,255,255,.2);}
.prof-av.open{border-color:var(--al);}
.prof-menu{position:absolute;top:calc(100% + 10px);right:0;background:linear-gradient(145deg,#0d1628,#080e1a);border:1px solid rgba(255,255,255,.12);border-radius:13px;padding:6px;min-width:190px;z-index:200;box-shadow:0 12px 40px rgba(0,0,0,.55);display:none;}
.prof-menu.open{display:block;animation:pf .2s ease;}
@keyframes pf{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.prof-menu-header{padding:10px 12px;border-bottom:1px solid rgba(255,255,255,.06);margin-bottom:5px;}
.prof-menu-name{font-size:13px;font-weight:700;color:var(--text);}
.prof-menu-email{font-size:11px;color:var(--sub);margin-top:2px;}
.prof-menu-item{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:9px;font-size:13px;font-weight:500;color:var(--sub2);cursor:pointer;transition:all .15s;text-decoration:none;}
.prof-menu-item:hover{background:rgba(255,255,255,.06);color:var(--text);}
.prof-menu-item.danger{color:rgba(239,68,68,.75);}
.prof-menu-item.danger:hover{background:rgba(239,68,68,.09);color:var(--red);}
.page{flex:1;overflow-y:auto;padding:1.8rem 2.4rem;scrollbar-width:none;}
.page::-webkit-scrollbar{display:none;}

/* ── SETTINGS ── */
.set-tabs{display:flex;align-items:center;gap:8px;margin-bottom:1.8rem;flex-wrap:wrap;}
.set-tab-btn{font-size:12px;color:var(--sub2);cursor:pointer;padding:7px 15px;border-radius:9px;border:1px solid var(--border);background:transparent;font-family:'Plus Jakarta Sans',sans-serif;font-weight:500;transition:all .18s;}
.set-tab-btn:hover{border-color:var(--border2);color:var(--text);}
.set-tab-btn.on{background:rgba(59,130,246,.12);border-color:rgba(59,130,246,.28);color:var(--al);}
.set-panel{display:none;}
.set-panel.on{display:block;animation:fadeIn .22s ease both;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.set-section{background:var(--bg3);border:1px solid var(--border);border-radius:15px;padding:1.4rem 1.6rem;margin-bottom:14px;transition:border-color .2s;}
.set-section:hover{border-color:var(--border2);}
.set-sh{font-size:13px;font-weight:700;color:var(--sub2);text-transform:uppercase;letter-spacing:.8px;margin-bottom:1.1rem;display:flex;align-items:center;gap:8px;}
.set-sh::after{content:'';flex:1;height:1px;background:var(--border);}
.set-row{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid rgba(255,255,255,.04);gap:24px;}
.set-row:last-child{border-bottom:none;padding-bottom:0;}
.set-lbl strong{display:block;font-size:13px;font-weight:600;color:var(--text);margin-bottom:2px;}
.set-lbl span{font-size:11.5px;color:var(--sub);line-height:1.5;}
.tog{position:relative;width:44px;height:24px;flex-shrink:0;}
.tog input{display:none;}
.tog-track{position:absolute;inset:0;background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:12px;cursor:pointer;transition:all .25s;}
.tog-track::after{content:'';position:absolute;top:3px;left:3px;width:16px;height:16px;border-radius:50%;background:var(--sub);transition:all .25s cubic-bezier(.4,0,.2,1);}
.tog input:checked+.tog-track{background:rgba(37,99,235,.3);border-color:rgba(37,99,235,.45);}
.tog input:checked+.tog-track::after{transform:translateX(20px);background:linear-gradient(135deg,var(--accent),var(--al));box-shadow:0 0 8px rgba(37,99,235,.5);}
.set-sel,.set-inp{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:8px;padding:8px 11px;color:var(--text);font-family:'Plus Jakarta Sans',sans-serif;font-size:12.5px;outline:none;cursor:pointer;transition:border-color .18s;min-width:130px;}
.set-sel:focus,.set-inp:focus{border-color:var(--accent);}
.set-sel option{background:var(--bg3);}
.set-inp{cursor:text;}
.set-inp::placeholder{color:var(--sub);}
.accent-row{display:flex;gap:8px;align-items:center;}
.accent-sw{width:26px;height:26px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:all .18s;position:relative;flex-shrink:0;}
.accent-sw:hover{transform:scale(1.2);}
.accent-sw.on{border-color:#fff;box-shadow:0 0 10px rgba(255,255,255,.25);}
.accent-sw.on::after{content:'✓';position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:10px;color:#fff;font-weight:800;}
.theme-row{display:flex;gap:8px;flex-wrap:wrap;}
.theme-chip{display:flex;align-items:center;gap:7px;padding:7px 13px;border-radius:9px;border:1px solid var(--border);background:transparent;cursor:pointer;font-size:12px;font-weight:500;color:var(--sub2);transition:all .18s;font-family:'Plus Jakarta Sans',sans-serif;}
.theme-chip:hover{border-color:var(--border2);color:var(--text);}
.theme-chip.on{background:rgba(59,130,246,.12);border-color:rgba(59,130,246,.28);color:var(--al);}
.theme-dot{width:11px;height:11px;border-radius:50%;border:1px solid rgba(255,255,255,.15);}
.set-av{width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--al));display:flex;align-items:center;justify-content:center;font-weight:800;font-size:20px;flex-shrink:0;}
.set-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:14px;}
.set-stat{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:11px;padding:10px 12px;text-align:center;}
.set-stat .sv{font-size:18px;font-weight:700;}
.set-stat .sl{font-size:10px;color:var(--sub);margin-top:2px;text-transform:uppercase;letter-spacing:.5px;}
.set-plan-tag{display:inline-flex;align-items:center;gap:4px;font-size:10.5px;font-weight:700;padding:3px 9px;border-radius:20px;background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.25);color:var(--gold);margin-left:6px;}
.set-plan-tag.premium{background:rgba(37,99,235,.15);border-color:rgba(37,99,235,.3);color:var(--al);}
.set-plan-tag.automated{background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.25);color:var(--gold);}
.set-plan-tag.autosignals{background:rgba(16,185,129,.15);border:1px solid rgba(16,185,129,.3);color:var(--green);}
.set-danger{padding:8px 16px;border-radius:9px;font-family:'Plus Jakarta Sans',sans-serif;font-size:12.5px;font-weight:600;cursor:pointer;transition:all .18s;border:1px solid rgba(239,68,68,.28);background:rgba(239,68,68,.07);color:var(--red);}
.set-danger:hover{background:rgba(239,68,68,.16);border-color:rgba(239,68,68,.45);}
.set-save{padding:9px 22px;border-radius:10px;border:none;background:linear-gradient(90deg,var(--accent),var(--al));color:#fff;font-family:'Plus Jakarta Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;}
.set-save:hover{box-shadow:0 0 28px rgba(37,99,235,.4);}
.set-save-gold{padding:9px 22px;border-radius:10px;border:none;background:linear-gradient(90deg,#059669,#10b981);color:#fff;font-family:'Plus Jakarta Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;}
.set-import-lbl{padding:8px 16px;border-radius:9px;border:1px solid var(--border);background:rgba(255,255,255,.03);color:var(--sub2);font-size:12.5px;font-weight:600;cursor:pointer;transition:all .18s;font-family:'Plus Jakarta Sans',sans-serif;}
.set-import-lbl:hover{border-color:var(--border2);color:var(--text);}
.set-signout{padding:9px 22px;border-radius:10px;border:1px solid rgba(239,68,68,.28);background:rgba(239,68,68,.07);color:var(--red);font-family:'Plus Jakarta Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;}
.set-signout:hover{background:rgba(239,68,68,.16);border-color:rgba(239,68,68,.45);}
.sub-info-box{background:linear-gradient(135deg,rgba(37,99,235,.12),rgba(59,130,246,.05));border:1px solid rgba(37,99,235,.25);border-radius:12px;padding:14px 16px;margin-top:12px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;}
.sub-info-label{font-size:12px;color:var(--sub2);line-height:1.6;}
.sub-info-label strong{display:block;font-size:13px;font-weight:700;color:var(--text);margin-bottom:2px;}

/* ── DASHBOARD CUSTOMIZATION ── */
/* Layout cards */
.layout-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.layout-card{border:1px solid var(--border);border-radius:11px;padding:14px 12px;cursor:pointer;transition:all .2s;background:rgba(255,255,255,.02);display:flex;flex-direction:column;align-items:center;gap:9px;}
.layout-card:hover{border-color:var(--border2);background:rgba(255,255,255,.04);}
.layout-card.on{border-color:rgba(59,130,246,.4);background:rgba(59,130,246,.08);}
.layout-card.on .lc-label{color:var(--al);}
.lc-preview{width:100%;height:40px;border-radius:6px;background:rgba(255,255,255,.04);border:1px solid var(--border);display:flex;gap:3px;padding:5px;overflow:hidden;}
.lc-preview .lc-col{border-radius:3px;background:rgba(255,255,255,.07);flex:1;}
.lc-preview .lc-col.wide{flex:2;}
.lc-label{font-size:11.5px;font-weight:600;color:var(--sub2);transition:color .2s;}

/* Chart style cards */
.chart-style-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.cs-card{border:1px solid var(--border);border-radius:11px;padding:12px;cursor:pointer;transition:all .2s;background:rgba(255,255,255,.02);display:flex;flex-direction:column;align-items:center;gap:8px;}
.cs-card:hover{border-color:var(--border2);background:rgba(255,255,255,.04);}
.cs-card.on{border-color:rgba(59,130,246,.4);background:rgba(59,130,246,.08);}
.cs-card.on .cs-label{color:var(--al);}
.cs-preview{width:100%;height:36px;border-radius:5px;display:flex;align-items:flex-end;gap:2px;padding:4px 4px 0;}
.cs-label{font-size:11.5px;font-weight:600;color:var(--sub2);transition:color .2s;}

/* Bar sparkline */
.sp-bar{border-radius:2px 2px 0 0;background:var(--green);flex:1;}
.sp-bar.r{background:var(--red);}
/* Line sparkline */
.sp-line{width:100%;height:100%;position:relative;}
.sp-line svg{width:100%;height:100%;}
/* Candle sparkline */
.sp-candle{display:flex;align-items:center;justify-content:center;gap:2px;width:100%;height:100%;}
.sp-c{display:flex;flex-direction:column;align-items:center;gap:1px;}
.sp-c-body{width:6px;border-radius:1px;}
.sp-c-wick{width:1.5px;border-radius:1px;}

/* Default page chips */
.page-chip-row{display:flex;gap:8px;flex-wrap:wrap;}
.page-chip{display:flex;align-items:center;gap:6px;padding:7px 13px;border-radius:9px;border:1px solid var(--border);background:transparent;cursor:pointer;font-size:12px;font-weight:500;color:var(--sub2);transition:all .18s;font-family:'Plus Jakarta Sans',sans-serif;}
.page-chip:hover{border-color:var(--border2);color:var(--text);}
.page-chip.on{background:rgba(59,130,246,.12);border-color:rgba(59,130,246,.28);color:var(--al);}

/* Density chips */
.density-row{display:flex;gap:8px;}
.density-chip{padding:7px 16px;border-radius:9px;border:1px solid var(--border);background:transparent;cursor:pointer;font-size:12px;font-weight:500;color:var(--sub2);transition:all .18s;font-family:'Plus Jakarta Sans',sans-serif;display:flex;flex-direction:column;align-items:center;gap:3px;}
.density-chip:hover{border-color:var(--border2);color:var(--text);}
.density-chip.on{background:rgba(59,130,246,.12);border-color:rgba(59,130,246,.28);color:var(--al);}
.density-chip small{font-size:10px;color:var(--sub);font-weight:400;}

/* Saved confirmation flash */
@keyframes flashSave{0%{opacity:0;transform:scale(.92)}60%{opacity:1;transform:scale(1.04)}100%{opacity:1;transform:scale(1)}}
.saved-flash{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;font-weight:600;color:var(--green);animation:flashSave .3s ease both;}

/* ── FONT SIZE SLIDER ── */
.font-slider-wrap{display:flex;align-items:center;gap:12px;flex:1;min-width:180px;}
.font-slider{-webkit-appearance:none;appearance:none;width:100%;height:5px;border-radius:3px;background:rgba(255,255,255,.08);outline:none;cursor:pointer;}
.font-slider::-webkit-slider-thumb{-webkit-appearance:none;width:16px;height:16px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--al));cursor:pointer;box-shadow:0 0 8px rgba(37,99,235,.5);}
.font-slider::-moz-range-thumb{width:16px;height:16px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--al));cursor:pointer;border:none;}
.font-size-preview{font-size:12px;color:var(--sub);min-width:32px;text-align:right;}

/* ── RADIUS CHIPS ── */
.radius-row{display:flex;gap:8px;}
.radius-chip{display:flex;flex-direction:column;align-items:center;gap:8px;padding:10px 14px;border-radius:9px;border:1px solid var(--border);background:transparent;cursor:pointer;font-size:12px;font-weight:500;color:var(--sub2);transition:all .18s;font-family:'Plus Jakarta Sans',sans-serif;}
.radius-chip:hover{border-color:var(--border2);color:var(--text);}
.radius-chip.on{background:rgba(59,130,246,.12);border-color:rgba(59,130,246,.28);color:var(--al);}
.radius-preview{width:28px;height:20px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);}

/* ── SIDEBAR WIDTH ── */
.sw-row{display:flex;gap:8px;}
.sw-chip{padding:7px 16px;border-radius:9px;border:1px solid var(--border);background:transparent;cursor:pointer;font-size:12px;font-weight:500;color:var(--sub2);transition:all .18s;font-family:'Plus Jakarta Sans',sans-serif;}
.sw-chip:hover{border-color:var(--border2);color:var(--text);}
.sw-chip.on{background:rgba(59,130,246,.12);border-color:rgba(59,130,246,.28);color:var(--al);}

/* ── SESSION / TRADING CHIPS ── */
.sess-row{display:flex;gap:8px;flex-wrap:wrap;}
.sess-chip{padding:7px 14px;border-radius:9px;border:1px solid var(--border);background:transparent;cursor:pointer;font-size:12px;font-weight:500;color:var(--sub2);transition:all .18s;font-family:'Plus Jakarta Sans',sans-serif;display:flex;align-items:center;gap:5px;}
.sess-chip:hover{border-color:var(--border2);color:var(--text);}
.sess-chip.on{background:rgba(59,130,246,.12);border-color:rgba(59,130,246,.28);color:var(--al);}

/* ── STREAMER MODE BADGE ── */
.streamer-badge{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-weight:700;padding:3px 9px;border-radius:20px;background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25);color:var(--red);margin-left:8px;vertical-align:middle;}

/* ── COLOR SWATCH SMALL ── */
.color-row{display:flex;gap:6px;flex-wrap:wrap;}
.color-sw{width:22px;height:22px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:all .18s;position:relative;flex-shrink:0;}
.color-sw:hover{transform:scale(1.2);}
.color-sw.on{border-color:#fff;box-shadow:0 0 8px rgba(255,255,255,.3);}
.color-sw.on::after{content:'✓';position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:9px;color:#fff;font-weight:800;}

/* ── TOAST ── */
.toast{position:fixed;bottom:24px;right:24px;z-index:9999;background:linear-gradient(145deg,var(--bg3),var(--bg2));border:1px solid var(--border2);border-radius:14px;padding:1.1rem 1.4rem;box-shadow:0 12px 40px rgba(0,0,0,.4);display:flex;align-items:center;gap:12px;animation:toastIn .4s ease;max-width:380px;}
@keyframes toastIn{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:translateX(0)}}
.toast-icon{font-size:24px;}
.toast-body{flex:1;}
.toast-title{font-size:14px;font-weight:700;margin-bottom:2px;}
.toast-msg{font-size:12px;color:var(--sub2);}
.toast-close{background:none;border:none;color:var(--sub);cursor:pointer;font-size:16px;padding:4px;}

/* ── MOBILE ── */
.mobile-toggle{display:none;align-items:center;justify-content:center;width:36px;height:36px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);font-size:18px;cursor:pointer;flex-shrink:0;}
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(4px);z-index:19;}

@media(max-width:850px){
  .mobile-toggle{display:flex;}
  .sidebar{position:fixed;left:0;top:0;transform:translateX(-100%);transition:transform .35s cubic-bezier(.4,0,.2,1);z-index:20;box-shadow:4px 0 30px rgba(0,0,0,.5);}
  .sidebar.open{transform:translateX(0);}
  .sidebar-overlay.open{display:block;}
  .main-wrap{width:100%;}
  .topbar{padding:1rem 1.2rem;}
  .page{padding:1.2rem 1.4rem;}
  .t-pill{display:none;}
  .set-stats{grid-template-columns:repeat(2,1fr);}
  .layout-grid,.chart-style-grid{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:600px){
  .page{padding:1rem;}
  .set-tabs{gap:6px;}
  .set-tab-btn{padding:6px 12px;font-size:11px;}
  .set-row{flex-wrap:wrap;gap:12px;}
  .set-lbl{flex:1;min-width:200px;}
  .set-stats{grid-template-columns:1fr 1fr;}
  .layout-grid,.chart-style-grid{grid-template-columns:1fr 1fr;}
}
.nav-affiliate-wrap { position: relative; display: inline-block; }
.nav-earn-badge { position: absolute; top: -9px; right: -28px; font-size: 8px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #34d399; background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.35); border-radius: 4px; padding: 2px 6px; line-height: 1.5; transform: rotate(12deg); pointer-events: none; white-space: nowrap; }
</style>


</head>
<body>
<div class="shell">

  <div class="sidebar-overlay" id="sb-overlay" onclick="closeSidebar()"></div>

        <!-- SIDEBAR -->
  <nav class="sidebar" id="sidebar">
    <a class="s-logo" href="https://trenai.vercel.app" style="text-decoration:none;color:inherit;">
      <span class="s-logo-dot"></span>
      tren<span>.</span>
    </a>

    <div class="s-nav">
      <div class="s-section-label">Trading</div>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/live-signals')">
        <span class="s-ic"><span class="live-dot-nav"></span></span><span>Live Signals</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/overview')">
        <span class="s-ic">📊</span><span>Overview</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/signals')">
        <span class="s-ic">⚡</span><span>Recent Trades</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/journal')">
        <span class="s-ic">📓</span><span>Journal</span>
      </a>

      <div class="s-divider"></div>
      <div class="s-section-label">Tools</div>
      <a class="s-item ai-item" onclick="navTo('https://trenai.vercel.app/ai-analysis')">
        <span class="s-ic">✨</span><span>AI Analysis</span>
        <span class="s-beta">BETA</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/trenbot')">
        <span class="s-ic">🤖</span><span>TrenBot</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/autosignals')">
        <span class="s-ic">⚡</span><span>AutoSignals</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/indicator')">
        <span class="s-ic">📈</span><span>Indicator</span>
      </a>

      <div class="s-divider"></div>
      <div class="s-section-label">Misc</div>
      <a class="s-item gold" onclick="navTo('https://trenai.vercel.app/upgrade')">
        <span class="s-ic">👑</span><span>Upgrade</span>
        <span class="s-badge">PRO</span>
      </a>
      <a class="s-item on" onclick="navTo('https://trenai.vercel.app/settings')">
        <span class="s-ic">⚙️</span><span>Settings</span>
      </a>
    </div>

    <div class="s-bot">
      <a class="u-row" onclick="navTo('https://trenai.vercel.app/settings')">
        <div class="u-av" id="s-av">T</div>
        <div class="u-info">
          <div class="u-name" id="s-nm">Trader</div>
          <div class="u-email" id="s-email-display">—</div>
          <span class="sub-status-badge trial" id="sidebar-plan-badge">⚡ Trial</span>
        </div>
      </a>
      <div class="s-logout" onclick="doLogout()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sign out
      </div>
    </div>
  </nav>

  <!-- MAIN -->
  <div class="main-wrap">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;">
        <button class="mobile-toggle" onclick="toggleSidebar()">☰</button>
        <div>
          <div class="tb-title">Settings</div>
          <div style="font-size:12px;color:var(--sub);margin-top:2px;">Preferences &amp; account options</div>
        </div>
      </div>
      <div class="tb-right">
        <div class="t-pill" id="trial-pill">⏱ <span id="pill-days">7</span> days left in trial</div>
        <div class="nb">🔔</div>
        <div class="prof-wrap">
          <div class="prof-av" id="prof-av-btn" onclick="toggleProfileMenu()">T</div>
          <div class="prof-menu" id="prof-menu">
            <div class="prof-menu-header">
              <div class="prof-menu-name" id="prof-menu-name">Trader</div>
              <div class="prof-menu-email" id="prof-menu-email">—</div>
            </div>
            <a class="prof-menu-item" href="https://trenai.vercel.app/settings">👤 Profile settings</a>
            <div class="prof-menu-item danger" onclick="doLogout()">→ Sign out</div>
          </div>
        </div>
      </div>
    </div>

    <!-- PAGE -->
    <div class="page">
      <div class="set-tabs">
        <button class="set-tab-btn on"  onclick="setTab('profile',this)">👤 Profile</button>
        <button class="set-tab-btn"     onclick="setTab('appearance',this)">🎨 Appearance</button>
        <button class="set-tab-btn"     onclick="setTab('dashboard',this)">🖥 Dashboard</button>
        <button class="set-tab-btn"     onclick="setTab('notifications',this)">🔔 Notifications</button>
        <button class="set-tab-btn"     onclick="setTab('trading',this)">📈 Trading</button>
        <button class="set-tab-btn"     onclick="setTab('privacy',this)">🔒 Privacy</button>
        <button class="set-tab-btn"     onclick="setTab('journal',this)">📓 Journal</button>
        <button class="set-tab-btn"     onclick="setTab('data',this)">💾 Data</button>
      </div>

      <!-- PROFILE -->
      <div class="set-panel on" id="sp-profile">
        <div class="set-section">
          <div class="set-sh">Account</div>
          <div class="set-row" style="padding-top:0;gap:16px;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:18px;flex:1;min-width:200px;">
              <div class="set-av" id="set-av-display">T</div>
              <div>
                <div style="font-size:15px;font-weight:800;" id="set-name-display">Trader</div>
                <div style="font-size:12px;color:var(--sub);margin-top:5px;" id="set-email-display">—</div>
                <span class="set-plan-tag" id="set-plan-tag" style="margin-top:4px;">⚡ Trial</span>
              </div>
            </div>
          </div>
          <div id="sub-info-box" style="display:none;" class="sub-info-box">
            <div class="sub-info-label"><strong>⚡ Active Subscription</strong><span id="sub-info-text">Premium plan · Active</span></div>
            <a href="https://trenai.vercel.app/contact" style="font-size:12px;color:var(--al);text-decoration:none;font-weight:600;flex-shrink:0;">Manage →</a>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Display Name</strong><span>Shown across the dashboard</span></div>
            <input class="set-inp" id="set-display-name" placeholder="e.g. Alex" maxlength="20">
          </div>
          <div class="set-row">
            <div></div>
            <button class="set-save" onclick="saveProfile()">Save Profile</button>
          </div>
        </div>
        <div class="set-section">
          <div class="set-sh">Your Stats</div>
          <div class="set-stats">
            <div class="set-stat"><div class="sv" id="ss-trades">—</div><div class="sl">Trades</div></div>
            <div class="set-stat"><div class="sv" id="ss-wr">—</div><div class="sl">Win Rate</div></div>
            <div class="set-stat"><div class="sv" id="ss-pnl">—</div><div class="sl">Total P&L</div></div>
            <div class="set-stat"><div class="sv" id="ss-days">—</div><div class="sl">Days Active</div></div>
          </div>
        </div>
        <div class="set-section" style="border-color:rgba(239,68,68,.15);">
          <div class="set-sh">Session</div>
          <div class="set-row">
            <div class="set-lbl"><strong>Sign Out</strong><span>End your current session.</span></div>
            <button class="set-signout" onclick="doLogout()">Sign Out</button>
          </div>
        </div>
      </div>

      <!-- APPEARANCE -->
      <div class="set-panel" id="sp-appearance">
        <div class="set-section">
          <div class="set-sh">Theme</div>
          <div class="set-row">
            <div class="set-lbl"><strong>Dashboard Theme</strong><span>Background colour style</span></div>
            <div class="theme-row">
              <div class="theme-chip on" data-theme="dark" onclick="setTheme('dark',this)"><div class="theme-dot" style="background:#04080f;"></div>Midnight</div>
              <div class="theme-chip" data-theme="deep" onclick="setTheme('deep',this)"><div class="theme-dot" style="background:#020810;border-color:rgba(59,130,246,.3);"></div>Deep Blue</div>
              <div class="theme-chip" data-theme="slate" onclick="setTheme('slate',this)"><div class="theme-dot" style="background:#0d1117;border-color:rgba(255,255,255,.2);"></div>Slate</div>
            </div>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Accent Color</strong><span>Highlights and active states</span></div>
            <div class="accent-row">
              <div class="accent-sw on" data-color="#2563eb" style="background:#2563eb;" onclick="setAccent('#2563eb','#3b82f6',this)"></div>
              <div class="accent-sw" data-color="#7c3aed" style="background:#7c3aed;" onclick="setAccent('#7c3aed','#8b5cf6',this)"></div>
              <div class="accent-sw" data-color="#059669" style="background:#059669;" onclick="setAccent('#059669','#10b981',this)"></div>
              <div class="accent-sw" data-color="#dc2626" style="background:#dc2626;" onclick="setAccent('#dc2626','#ef4444',this)"></div>
              <div class="accent-sw" data-color="#d97706" style="background:#d97706;" onclick="setAccent('#d97706','#f59e0b',this)"></div>
              <div class="accent-sw" data-color="#0891b2" style="background:#0891b2;" onclick="setAccent('#0891b2','#06b6d4',this)"></div>
            </div>
          </div>
        </div>

        <div class="set-section">
          <div class="set-sh">Typography</div>
          <div class="set-row">
            <div class="set-lbl"><strong>Interface Font Size</strong><span>Base text size across the dashboard</span></div>
            <div class="font-slider-wrap">
              <span style="font-size:10px;color:var(--sub);">A</span>
              <input type="range" class="font-slider" id="font-size-slider" min="12" max="17" step="1" value="14" oninput="setFontSize(this.value)">
              <span style="font-size:15px;color:var(--sub);">A</span>
              <span class="font-size-preview" id="font-size-preview">14px</span>
            </div>
          </div>
        </div>

        <div class="set-section">
          <div class="set-sh">Shape &amp; Layout</div>
          <div class="set-row">
            <div class="set-lbl"><strong>Border Radius</strong><span>Corner style for cards and buttons</span></div>
            <div class="radius-row" id="radius-row">
              <button class="radius-chip" data-radius="sharp" onclick="setRadius('sharp',this)">
                <div class="radius-preview" style="border-radius:2px;"></div>Sharp
              </button>
              <button class="radius-chip on" data-radius="default" onclick="setRadius('default',this)">
                <div class="radius-preview" style="border-radius:8px;"></div>Default
              </button>
              <button class="radius-chip" data-radius="pill" onclick="setRadius('pill',this)">
                <div class="radius-preview" style="border-radius:14px;"></div>Rounded
              </button>
            </div>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Sidebar Width</strong><span>How wide the left navigation panel is</span></div>
            <div class="sw-row" id="sw-row">
              <button class="sw-chip" data-sw="slim" onclick="setSidebarWidth('slim',this)">Slim</button>
              <button class="sw-chip on" data-sw="normal" onclick="setSidebarWidth('normal',this)">Normal</button>
              <button class="sw-chip" data-sw="wide" onclick="setSidebarWidth('wide',this)">Wide</button>
            </div>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Reduce Motion</strong><span>Disable card animations and transitions</span></div>
            <label class="tog"><input type="checkbox" id="tog-reduce-motion" onchange="savePref('reduce_motion',this.checked);applyReduceMotion(this.checked)"><div class="tog-track"></div></label>
          </div>
        </div>
      </div>

      <!-- DASHBOARD CUSTOMIZATION -->
      <div class="set-panel" id="sp-dashboard">

        <!-- Default Landing Page -->
        <div class="set-section">
          <div class="set-sh">Default Landing Page</div>
          <div class="set-row" style="flex-wrap:wrap;gap:12px;">
            <div class="set-lbl"><strong>Open To</strong><span>Which page loads when you first sign in</span></div>
            <div class="page-chip-row" id="default-page-row">
              <div class="page-chip on" data-page="overview"        onclick="setDefaultPage('overview',this)">📊 Overview</div>
              <div class="page-chip"    data-page="live-signals"    onclick="setDefaultPage('live-signals',this)"><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 5px var(--green);margin-right:4px;"></span>Live Signals</div>
              <div class="page-chip"    data-page="signals"         onclick="setDefaultPage('signals',this)">⚡ Recent Trades</div>
              <div class="page-chip"    data-page="journal"         onclick="setDefaultPage('journal',this)">📓 Journal</div>
            </div>
          </div>
        </div>

        <!-- Overview Card Layout -->
        <div class="set-section">
          <div class="set-sh">Overview Card Layout</div>
          <div class="set-row" style="flex-wrap:wrap;align-items:flex-start;gap:16px;">
            <div class="set-lbl"><strong>Stat Cards Arrangement</strong><span>How the top stat cards are laid out</span></div>
            <div class="layout-grid" id="layout-grid" style="flex:1;min-width:240px;">
              <!-- 4 equal -->
              <div class="layout-card on" data-layout="equal4" onclick="setLayout('equal4',this)">
                <div class="lc-preview">
                  <div class="lc-col"></div><div class="lc-col"></div><div class="lc-col"></div><div class="lc-col"></div>
                </div>
                <div class="lc-label">4 Equal</div>
              </div>
              <!-- 2+2 stacked -->
              <div class="layout-card" data-layout="grid2x2" onclick="setLayout('grid2x2',this)">
                <div class="lc-preview" style="flex-direction:column;gap:3px;">
                  <div style="display:flex;gap:3px;flex:1;"><div class="lc-col"></div><div class="lc-col"></div></div>
                  <div style="display:flex;gap:3px;flex:1;"><div class="lc-col"></div><div class="lc-col"></div></div>
                </div>
                <div class="lc-label">2 × 2 Grid</div>
              </div>
              <!-- Wide + 2 -->
              <div class="layout-card" data-layout="wide1" onclick="setLayout('wide1',this)">
                <div class="lc-preview">
                  <div class="lc-col wide"></div><div class="lc-col"></div><div class="lc-col"></div>
                </div>
                <div class="lc-label">Featured + 2</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Chart Style -->
        <div class="set-section">
          <div class="set-sh">P&amp;L Chart Style</div>
          <div class="set-row" style="flex-wrap:wrap;align-items:flex-start;gap:16px;">
            <div class="set-lbl"><strong>Chart Type</strong><span>How performance is visualised on the overview chart</span></div>
            <div class="chart-style-grid" id="chart-style-grid" style="flex:1;min-width:240px;">
              <!-- Bar chart -->
              <div class="cs-card on" data-style="bar" onclick="setChartStyle('bar',this)">
                <div class="cs-preview">
                  <div class="sp-bar" style="height:60%"></div>
                  <div class="sp-bar r" style="height:35%"></div>
                  <div class="sp-bar" style="height:80%"></div>
                  <div class="sp-bar r" style="height:20%"></div>
                  <div class="sp-bar" style="height:55%"></div>
                  <div class="sp-bar" style="height:90%"></div>
                  <div class="sp-bar r" style="height:40%"></div>
                </div>
                <div class="cs-label">Bar</div>
              </div>
              <!-- Line chart -->
              <div class="cs-card" data-style="line" onclick="setChartStyle('line',this)">
                <div class="cs-preview" style="padding:0;align-items:stretch;">
                  <svg viewBox="0 0 80 36" preserveAspectRatio="none" style="width:100%;height:100%;">
                    <polyline points="0,30 12,22 24,26 36,14 48,18 60,8 72,12 80,4" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <polygon points="0,30 12,22 24,26 36,14 48,18 60,8 72,12 80,4 80,36 0,36" fill="rgba(16,185,129,.12)"/>
                  </svg>
                </div>
                <div class="cs-label">Line</div>
              </div>
              <!-- Cumulative -->
              <div class="cs-card" data-style="cumulative" onclick="setChartStyle('cumulative',this)">
                <div class="cs-preview" style="padding:0;align-items:stretch;">
                  <svg viewBox="0 0 80 36" preserveAspectRatio="none" style="width:100%;height:100%;">
                    <polyline points="0,34 12,30 24,28 36,20 48,16 60,10 72,7 80,4" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <polygon points="0,34 12,30 24,28 36,20 48,16 60,10 72,7 80,4 80,36 0,36" fill="rgba(59,130,246,.12)"/>
                  </svg>
                </div>
                <div class="cs-label">Cumulative</div>
              </div>
            </div>
          </div>
        </div>

        <!-- UI Density -->
        <div class="set-section">
          <div class="set-sh">Interface Density</div>
          <div class="set-row" style="flex-wrap:wrap;gap:12px;">
            <div class="set-lbl"><strong>Spacing</strong><span>How compact the dashboard feels</span></div>
            <div class="density-row" id="density-row">
              <div class="density-chip" data-density="compact" onclick="setDensity('compact',this)">
                Compact<small>Tighter rows</small>
              </div>
              <div class="density-chip on" data-density="default" onclick="setDensity('default',this)">
                Default<small>Balanced</small>
              </div>
              <div class="density-chip" data-density="relaxed" onclick="setDensity('relaxed',this)">
                Relaxed<small>More breathing room</small>
              </div>
            </div>
          </div>
        </div>

        <!-- Visible Sections -->
        <div class="set-section">
          <div class="set-sh">Overview Sections</div>
          <div class="set-row">
            <div class="set-lbl"><strong>Show P&amp;L Chart</strong><span>Display the daily performance bar chart</span></div>
            <label class="tog"><input type="checkbox" id="tog-show-chart" checked onchange="savePref('show_chart',this.checked)"><div class="tog-track"></div></label>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Show NQ Futures Chart</strong><span>Display the NASDAQ futures live chart</span></div>
            <label class="tog"><input type="checkbox" id="tog-show-nq" checked onchange="savePref('show_nq',this.checked)"><div class="tog-track"></div></label>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Show Day-of-Week Performance</strong><span>Display which days of the week you trade best</span></div>
            <label class="tog"><input type="checkbox" id="tog-show-dow" checked onchange="savePref('show_dow',this.checked)"><div class="tog-track"></div></label>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Show Edge Metrics</strong><span>Win/Loss split, R:R, Profit Factor, Streak cards</span></div>
            <label class="tog"><input type="checkbox" id="tog-show-edge" checked onchange="savePref('show_edge',this.checked)"><div class="tog-track"></div></label>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Show Trade Intelligence</strong><span>Hold time, Best/Worst trade, Consistency cards</span></div>
            <label class="tog"><input type="checkbox" id="tog-show-intel" checked onchange="savePref('show_intel',this.checked)"><div class="tog-track"></div></label>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Show Latest Signals</strong><span>Display the recent signal cards below the chart</span></div>
            <label class="tog"><input type="checkbox" id="tog-show-sigs" checked onchange="savePref('show_signals',this.checked)"><div class="tog-track"></div></label>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Animate Cards on Load</strong><span>Subtle fade-in when the dashboard opens</span></div>
            <label class="tog"><input type="checkbox" id="tog-animate" checked onchange="savePref('animate_cards',this.checked)"><div class="tog-track"></div></label>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Show Weekend Bars</strong><span>Include Sat &amp; Sun as dimmed bars in the P&amp;L chart</span></div>
            <label class="tog"><input type="checkbox" id="tog-wknd-chart" onchange="savePref('chart_weekends',this.checked)"><div class="tog-track"></div></label>
          </div>
        </div>

        <!-- Default Timeframe -->
        <div class="set-section">
          <div class="set-sh">Default Timeframe</div>
          <div class="set-row" style="flex-wrap:wrap;gap:12px;">
            <div class="set-lbl"><strong>Overview Timeframe</strong><span>Which period is selected when the overview first loads</span></div>
            <div class="sess-row" id="default-tf-row">
              <button class="sess-chip" data-tf="7"   onclick="setDefaultTF('7',this)">7D</button>
              <button class="sess-chip on" data-tf="14"  onclick="setDefaultTF('14',this)">14D</button>
              <button class="sess-chip" data-tf="30"  onclick="setDefaultTF('30',this)">30D</button>
              <button class="sess-chip" data-tf="90"  onclick="setDefaultTF('90',this)">90D</button>
              <button class="sess-chip" data-tf="365" onclick="setDefaultTF('365',this)">1Y</button>
            </div>
          </div>
        </div>


        <!-- Save button -->
        <div style="display:flex;align-items:center;gap:14px;justify-content:flex-end;margin-top:4px;">
          <span id="dash-saved-msg" style="display:none;"></span>
          <button class="set-save" onclick="saveDashboardSettings()">Save Dashboard Settings</button>
        </div>
      </div>

      <!-- NOTIFICATIONS -->
      <div class="set-panel" id="sp-notifications">
        <div class="set-section">
          <div class="set-sh">Browser Alerts</div>
          <div class="set-row">
            <div class="set-lbl"><strong>Enable Notifications</strong><span>Get alerted when new live trades are entered</span></div>
            <label class="tog"><input type="checkbox" id="tog-notif-main" onchange="handleNotifToggle(this.checked)"><div class="tog-track"></div></label>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Sound Alerts</strong><span>Play a chime when a new signal fires</span></div>
            <label class="tog"><input type="checkbox" id="tog-sound" onchange="savePref('sound_alerts',this.checked)"><div class="tog-track"></div></label>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Notify on Win Only</strong><span>Only notify when a trade closes in profit</span></div>
            <label class="tog"><input type="checkbox" id="tog-notif-win" onchange="savePref('notif_wins_only',this.checked)"><div class="tog-track"></div></label>
          </div>
        </div>
        <div class="set-section">
          <div class="set-sh">Quiet Hours</div>
          <div class="set-row">
            <div class="set-lbl"><strong>Enable Quiet Hours</strong><span>Suppress notifications during set hours</span></div>
            <label class="tog"><input type="checkbox" id="tog-quiet" onchange="toggleQuietHours(this.checked)"><div class="tog-track"></div></label>
          </div>
          <div id="quiet-hours-wrap" style="display:none;">
            <div class="set-row">
              <div class="set-lbl"><strong>From</strong><span>Start of quiet period</span></div>
              <input type="time" class="set-inp" id="quiet-from" value="22:00" onchange="savePref('quiet_from',this.value)" style="min-width:110px;">
            </div>
            <div class="set-row">
              <div class="set-lbl"><strong>Until</strong><span>End of quiet period</span></div>
              <input type="time" class="set-inp" id="quiet-until" value="08:00" onchange="savePref('quiet_until',this.value)" style="min-width:110px;">
            </div>
          </div>
        </div>
      </div>

      <!-- TRADING -->
      <div class="set-panel" id="sp-trading">

        <div class="set-section">
          <div class="set-sh">Performance Goals</div>
          <div class="set-row">
            <div class="set-lbl"><strong>Daily P&amp;L Target</strong><span>Your goal profit for a trading day</span></div>
            <div style="display:flex;align-items:center;gap:8px;">
              <span style="font-size:13px;color:var(--sub);">$</span>
              <input class="set-inp" type="number" id="daily-target-inp" placeholder="e.g. 500" min="0" onchange="savePref('daily_target',this.value)" style="min-width:110px;">
            </div>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Daily Drawdown Limit</strong><span>Stop trading if losses hit this amount</span></div>
            <div style="display:flex;align-items:center;gap:8px;">
              <span style="font-size:13px;color:var(--sub);">$</span>
              <input class="set-inp" type="number" id="daily-loss-inp" placeholder="e.g. 200" min="0" onchange="savePref('daily_loss_limit',this.value)" style="min-width:110px;">
            </div>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Win Rate Target</strong><span>Your goal win rate % to display on the overview</span></div>
            <div style="display:flex;align-items:center;gap:8px;">
              <input class="set-inp" type="number" id="wr-target-inp" placeholder="e.g. 60" min="0" max="100" onchange="savePref('wr_target',this.value)" style="min-width:80px;">
              <span style="font-size:13px;color:var(--sub);">%</span>
            </div>
          </div>
          <div class="set-row">
            <div></div>
            <button class="set-save" onclick="saveTradingSettings()">Save Trading Settings</button>
          </div>
        </div>
      </div>

      <!-- PRIVACY -->
      <div class="set-panel" id="sp-privacy">
        <div class="set-section">
          <div class="set-sh">Streamer Mode</div>
          <div class="set-row">
            <div class="set-lbl">
              <strong>Blur P&amp;L on Load <span class="streamer-badge">🎙 STREAMER</span></strong>
              <span>Numbers are blurred until you hover — great for screen-sharing</span>
            </div>
            <label class="tog"><input type="checkbox" id="tog-streamer" onchange="savePref('streamer_mode',this.checked);showToast('🎙','Streamer Mode '+(this.checked?'On':'Off'),'')"><div class="tog-track"></div></label>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Hide Email in UI</strong><span>Mask your email address on the dashboard</span></div>
            <label class="tog"><input type="checkbox" id="tog-hide-email" onchange="savePref('hide_email',this.checked)"><div class="tog-track"></div></label>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Hide Account Size</strong><span>Don't display account size on overview cards</span></div>
            <label class="tog"><input type="checkbox" id="tog-hide-account" onchange="savePref('hide_account_size',this.checked)"><div class="tog-track"></div></label>
          </div>
        </div>

        <div class="set-section">
          <div class="set-sh">Session Security</div>
          <div class="set-row">
            <div class="set-lbl"><strong>Auto-Lock After Inactivity</strong><span>Require re-authentication after you've been idle</span></div>
            <select class="set-sel" id="auto-lock-sel" onchange="savePref('auto_lock',this.value)">
              <option value="never">Never</option>
              <option value="15">15 minutes</option>
              <option value="30">30 minutes</option>
              <option value="60">1 hour</option>
              <option value="240">4 hours</option>
            </select>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Remember Login</strong><span>Stay signed in across browser sessions</span></div>
            <label class="tog"><input type="checkbox" id="tog-remember" checked onchange="savePref('remember_login',this.checked)"><div class="tog-track"></div></label>
          </div>
        </div>
      </div>

      <!-- JOURNAL -->
      <div class="set-panel" id="sp-journal">
        <div class="set-section">
          <div class="set-sh">Journal Display</div>
          <div class="set-row">
            <div class="set-lbl"><strong>Highlight Weekends</strong><span>Slightly dim Saturday &amp; Sunday on the calendar</span></div>
            <label class="tog"><input type="checkbox" id="tog-wknd" onchange="savePref('show_weekends',this.checked)"><div class="tog-track"></div></label>
          </div>
        </div>
      </div>

      <!-- DATA -->
      <div class="set-panel" id="sp-data">
        <div class="set-section">
          <div class="set-sh">Journal Backup</div>
          <div class="set-row">
            <div class="set-lbl"><strong>Export as CSV</strong><span>Download all trades as a spreadsheet</span></div>
            <button class="set-save" onclick="exportCSV()">Export CSV</button>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Export as JSON</strong><span>Full backup — can be re-imported later</span></div>
            <button class="set-save-gold" onclick="exportJSON()">Export JSON</button>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Import Trades</strong><span>Restore from a previous JSON backup</span></div>
            <label class="set-import-lbl">Import JSON<input type="file" accept=".json" style="display:none" onchange="importJSON(this)"></label>
          </div>
        </div>
        <div class="set-section">
          <div class="set-sh">Storage Info</div>
          <div class="set-row"><div class="set-lbl"><strong>Logged Trades</strong></div><span style="font-size:13px;font-weight:700;color:var(--al)" id="set-trade-count">—</span></div>
          <div class="set-row"><div class="set-lbl"><strong>Timezone</strong></div><span style="font-size:12.5px;color:var(--sub)" id="set-tz-info">—</span></div>
          <div class="set-row"><div class="set-lbl"><strong>App Version</strong></div><span style="font-size:12.5px;color:var(--sub)">Tren v1.0.0</span></div>
        </div>
        <div class="set-section" style="border-color:rgba(239,68,68,.18);">
          <div class="set-sh" style="color:var(--red);">Danger Zone</div>
          <div class="set-row">
            <div class="set-lbl"><strong>Clear All Journal Trades</strong><span>Permanently delete every trade. Cannot be undone.</span></div>
            <button class="set-danger" onclick="clearJournal()">Clear Trades</button>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Restore Hidden Live Cards</strong><span>Bring back trades you cleared from Live view</span></div>
            <button class="set-danger" style="border-color:rgba(245,158,11,.28);background:rgba(245,158,11,.07);color:var(--gold);" onclick="clearHiddenTrades()">Restore Cards</button>
          </div>
          <div class="set-row">
            <div class="set-lbl"><strong>Reset All Settings</strong><span>Wipe preferences back to defaults. Journal data is kept.</span></div>
            <button class="set-danger" onclick="resetSettings()">Reset Settings</button>
          </div>
        </div>
      </div>

    </div><!-- end .page -->
  </div><!-- end .main-wrap -->
</div><!-- end .shell -->

<script>
// ── CORE ──────────────────────────────────────────────────────────
const SUPABASE_AUTH_URL='https://sjntsmzbiqvtstvofcnx.supabase.co';
const SUPABASE_AUTH_KEY='sb_publishable_n0q0FsM9hZARXxKKIDprFw_O6GJfRAg';
const SESSION_KEY='tren_session';

let _session=window.__trenSession||(()=>{try{const r=localStorage.getItem(SESSION_KEY);return r?JSON.parse(r):null;}catch{return null;}})();
if(!(_session&&_session.access_token)){window.location.href='https://trenai.vercel.app/login-page';}

let _subData=null,_autoSubData=null,_autoSignalsSubData=null;
try{_subData=JSON.parse(localStorage.getItem('tren_sub')||'null');}catch(e){}
try{_autoSubData=JSON.parse(localStorage.getItem('tren_trenbot_sub')||'null');}catch(e){}
try{_autoSignalsSubData=JSON.parse(localStorage.getItem('tren_autosignals_sub')||'null');}catch(e){}

function getSessionEmail(){return _session&&_session.user&&_session.user.email?_session.user.email:'—';}
function getSessionFullName(){if(_session&&_session.user){const m=_session.user.user_metadata||{};if(m.full_name)return m.full_name;if(m.name)return m.name;if(_session.user.email)return _session.user.email.split('@')[0].replace(/[._]/g,' ').replace(/\b\w/g,c=>c.toUpperCase());}return'Trader';}
function getPrefs(){return JSON.parse(localStorage.getItem('tren_prefs')||'{}');}
function savePrefs(p){localStorage.setItem('tren_prefs',JSON.stringify(p));}
function savePref(k,v){const p=getPrefs();p[k]=v;savePrefs(p);}
function getUserDisplayName(){const e=getSessionEmail(),p=getPrefs(),u=p.display_names||{};return u[e]||getSessionFullName();}
function getTrades(){return JSON.parse(localStorage.getItem('tren_journal')||'[]');}
function getUserTimezone(){return Intl.DateTimeFormat().resolvedOptions().timeZone;}
function escHtml(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function showToast(icon,title,msg){const ex=document.querySelector('.toast');if(ex)ex.remove();const t=document.createElement('div');t.className='toast';t.innerHTML=`<div class="toast-icon">${icon}</div><div class="toast-body"><div class="toast-title">${escHtml(title)}</div><div class="toast-msg">${escHtml(msg)}</div></div><button class="toast-close" onclick="this.parentElement.remove()">✕</button>`;document.body.appendChild(t);setTimeout(()=>{if(t.parentElement)t.remove();},5000);}
function dlFile(content,filename,type){const blob=new Blob([content],{type});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download=filename;a.click();URL.revokeObjectURL(url);}

async function doLogout(){
  const tok=_session?_session.access_token:'';
  localStorage.removeItem(SESSION_KEY);
  ['tren_sub','tren_prefs','tren_auto_sub','tren_autosignals_sub','tren_trenbot_sub'].forEach(k=>localStorage.removeItem(k));
  try{fetch(`${SUPABASE_AUTH_URL}/auth/v1/logout`,{method:'POST',headers:{'apikey':SUPABASE_AUTH_KEY,'Authorization':'Bearer '+tok}}).catch(()=>{});}catch(e){}
  window.location.href='https://trenai.vercel.app/login-page';
}

function initUserInfo(){
  const name=getUserDisplayName(),email=getSessionEmail(),init=name.charAt(0).toUpperCase();
  ['s-nm','prof-menu-name'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=name;});
  ['s-av','prof-av-btn','set-av-display'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=init;});
  ['s-email-display','set-email-display'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=email;});
  const pe=document.getElementById('prof-menu-email');if(pe)pe.textContent=email;
  const nd=document.getElementById('set-name-display');if(nd)nd.textContent=name;
  const dn=document.getElementById('set-display-name');if(dn)dn.value=name===getSessionFullName()?'':name;
}

function initSubUI(){
  const hasTB=_autoSubData?.status==='active'&&_autoSubData?.plan==='trenbot';
  const hasAS=_autoSignalsSubData?.status==='active'&&_autoSignalsSubData?.plan==='auto';
  const hasP=_subData?.status&&_subData.status!=='inactive'&&_subData.status!=='cancelled';
  const tc=document.getElementById('trial-card'),tp=document.getElementById('trial-pill'),sb=document.getElementById('sidebar-plan-badge');
  const pt=document.getElementById('set-plan-tag'),box=document.getElementById('sub-info-box'),txt=document.getElementById('sub-info-text');
  if(hasTB||hasAS||hasP){
    if(tc)tc.style.display='none';
    let lbl='⚡ Premium',cls='premium',pn='Premium Signals';
    if(hasTB){lbl='⚡ TrenBot';cls='automated';pn='TrenBot';}
    else if(hasAS){lbl='⚡ AutoSignals';cls='autosignals';pn='AutoSignals';}
    if(tp){tp.textContent=lbl+' Active';tp.className='t-pill '+cls;}
    if(sb){sb.textContent=lbl;sb.className='sub-status-badge '+cls;}
    if(pt){pt.textContent=lbl;pt.className='set-plan-tag '+cls;}
    const sub=hasTB?_autoSubData:hasAS?_autoSignalsSubData:_subData;
    if(box&&txt){txt.textContent=`${pn} · ${sub?.billing==='yearly'?'Yearly':'Monthly'} · Active`;box.style.display='flex';}
  }else{
    if(pt){pt.textContent='⚡ Trial';pt.className='set-plan-tag';}
    if(box)box.style.display='none';
  }
}

function initStats(){
  const trades=getTrades();
  const pnl=trades.reduce((a,t)=>a+parseFloat(t.pnl||0),0);
  const wins=trades.filter(t=>parseFloat(t.pnl||0)>0).length;
  const wr=trades.length?Math.round(wins/trades.length*100):0;
  const days=new Set(trades.map(t=>t.date)).size;
  document.getElementById('ss-trades').textContent=trades.length;
  document.getElementById('ss-wr').textContent=wr+'%';
  document.getElementById('ss-pnl').textContent=(pnl>=0?'+':'')+'$'+Math.abs(pnl).toFixed(0);
  document.getElementById('ss-days').textContent=days;
  const tc=document.getElementById('set-trade-count');if(tc)tc.textContent=trades.length+' trades';
  const tz=document.getElementById('set-tz-info');if(tz)tz.textContent=getUserTimezone();
}

function initToggles(){
  const p=getPrefs();
  if(document.getElementById('tog-wknd'))document.getElementById('tog-wknd').checked=!!p.show_weekends;
  const no=localStorage.getItem('tren_notif')==='true';
  if(document.getElementById('tog-notif-main'))document.getElementById('tog-notif-main').checked=no;
  if(p.accent)document.querySelectorAll('.accent-sw').forEach(s=>s.classList.toggle('on',s.dataset.color===p.accent));
  if(p.theme)document.querySelectorAll('.theme-chip').forEach(c=>c.classList.toggle('on',c.dataset.theme===p.theme));

  // Dashboard prefs
  const sc=document.getElementById('tog-show-chart');if(sc)sc.checked=p.show_chart!==false;
  const ss=document.getElementById('tog-show-sigs');if(ss)ss.checked=p.show_signals!==false;
  const an=document.getElementById('tog-animate');if(an)an.checked=p.animate_cards!==false;
  const wc=document.getElementById('tog-wknd-chart');if(wc)wc.checked=!!p.chart_weekends;

  // New dashboard toggles
  const snq=document.getElementById('tog-show-nq');if(snq)snq.checked=p.show_nq!==false;
  const sdow=document.getElementById('tog-show-dow');if(sdow)sdow.checked=p.show_dow!==false;
  const sedge=document.getElementById('tog-show-edge');if(sedge)sedge.checked=p.show_edge!==false;
  const sintel=document.getElementById('tog-show-intel');if(sintel)sintel.checked=p.show_intel!==false;

  // Layout
  if(p.card_layout){
    document.querySelectorAll('.layout-card').forEach(c=>c.classList.toggle('on',c.dataset.layout===p.card_layout));
  }
  // Chart style
  if(p.chart_style){
    document.querySelectorAll('.cs-card').forEach(c=>c.classList.toggle('on',c.dataset.style===p.chart_style));
  }
  // Density
  if(p.density){
    document.querySelectorAll('.density-chip').forEach(c=>c.classList.toggle('on',c.dataset.density===p.density));
  }
  // Default page
  if(p.default_page){
    document.querySelectorAll('.page-chip').forEach(c=>c.classList.toggle('on',c.dataset.page===p.default_page));
  }

  // ── NEW: Appearance ──
  if(p.font_size){
    const sl=document.getElementById('font-size-slider');
    if(sl){sl.value=p.font_size;document.getElementById('font-size-preview').textContent=p.font_size+'px';}
    document.documentElement.style.setProperty('--ui-font-size',p.font_size+'px');
  }
  if(p.radius){
    document.querySelectorAll('.radius-chip').forEach(c=>c.classList.toggle('on',c.dataset.radius===p.radius));
    const R={sharp:'2px',default:'13px',pill:'20px'};
    document.documentElement.style.setProperty('--card-radius',R[p.radius]||R.default);
  }
  if(p.sidebar_width){
    document.querySelectorAll('.sw-chip').forEach(c=>c.classList.toggle('on',c.dataset.sw===p.sidebar_width));
    const W={slim:'180px',normal:'220px',wide:'260px'};
    document.documentElement.style.setProperty('--sw',W[p.sidebar_width]||W.normal);
  }
  const rm=document.getElementById('tog-reduce-motion');if(rm){rm.checked=!!p.reduce_motion;if(p.reduce_motion)applyReduceMotion(true);}

  // ── NEW: Notifications ──
  const ts=document.getElementById('tog-sound');if(ts)ts.checked=!!p.sound_alerts;
  const tnw=document.getElementById('tog-notif-win');if(tnw)tnw.checked=!!p.notif_wins_only;
  const tq=document.getElementById('tog-quiet');if(tq)tq.checked=!!p.quiet_hours;
  if(p.quiet_hours){const w=document.getElementById('quiet-hours-wrap');if(w)w.style.display='block';}
  if(p.quiet_from){const el=document.getElementById('quiet-from');if(el)el.value=p.quiet_from;}
  if(p.quiet_until){const el=document.getElementById('quiet-until');if(el)el.value=p.quiet_until;}

  // ── NEW: Trading ──
  if(p.preferred_session){
    document.querySelectorAll('#session-row .sess-chip').forEach(c=>c.classList.toggle('on',c.dataset.sess===p.preferred_session));
  }
  if(p.default_timeframe){
    document.querySelectorAll('#default-tf-row .sess-chip').forEach(c=>c.classList.toggle('on',c.dataset.tf===p.default_timeframe));
  }
  if(p.account_size){const el=document.getElementById('account-size-inp');if(el)el.value=p.account_size;}
  if(p.max_risk_pct){const el=document.getElementById('max-risk-inp');if(el)el.value=p.max_risk_pct;}
  if(p.daily_target){const el=document.getElementById('daily-target-inp');if(el)el.value=p.daily_target;}
  if(p.daily_loss_limit){const el=document.getElementById('daily-loss-inp');if(el)el.value=p.daily_loss_limit;}
  if(p.wr_target){const el=document.getElementById('wr-target-inp');if(el)el.value=p.wr_target;}
  if(p.instrument){const el=document.getElementById('instrument-sel');if(el)el.value=p.instrument;}
  if(p.pnl_format){const el=document.getElementById('pnl-format-sel');if(el)el.value=p.pnl_format;}
  if(p.currency){const el=document.getElementById('currency-sel');if(el)el.value=p.currency;}

  // ── NEW: Privacy ──
  const tstr=document.getElementById('tog-streamer');if(tstr)tstr.checked=!!p.streamer_mode;
  const the=document.getElementById('tog-hide-email');if(the)the.checked=!!p.hide_email;
  const tha=document.getElementById('tog-hide-account');if(tha)tha.checked=!!p.hide_account_size;
  const tal=document.getElementById('auto-lock-sel');if(tal&&p.auto_lock)tal.value=p.auto_lock;
  const trm=document.getElementById('tog-remember');if(trm)trm.checked=p.remember_login!==false;
}

function toggleProfileMenu(){
  const m=document.getElementById('prof-menu'),b=document.getElementById('prof-av-btn');
  const o=m.classList.contains('open');m.classList.toggle('open',!o);b.classList.toggle('open',!o);
}
document.addEventListener('click',e=>{
  const pw=document.querySelector('.prof-wrap');
  if(pw&&!pw.contains(e.target)){document.getElementById('prof-menu').classList.remove('open');document.getElementById('prof-av-btn').classList.remove('open');}
  const sb=document.getElementById('sidebar');
  if(window.innerWidth<=850&&sb.classList.contains('open')&&!sb.contains(e.target)&&!document.querySelector('.mobile-toggle').contains(e.target)){closeSidebar();}
});
function toggleSidebar(){document.getElementById('sidebar').classList.toggle('open');document.getElementById('sb-overlay').classList.toggle('open');}
function closeSidebar(){document.getElementById('sidebar').classList.remove('open');document.getElementById('sb-overlay').classList.remove('open');}

// ── SETTINGS LOGIC ────────────────────────────────────────────────
function setTab(id,el){
  document.querySelectorAll('.set-panel').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.set-tab-btn').forEach(b=>b.classList.remove('on'));
  document.getElementById('sp-'+id).classList.add('on');
  if(el)el.classList.add('on');
}

function saveProfile(){
  const name=document.getElementById('set-display-name').value.trim()||getSessionFullName();
  const email=getSessionEmail();const p=getPrefs();
  if(!p.display_names)p.display_names={};p.display_names[email]=name;savePrefs(p);
  ['set-name-display','s-nm','prof-menu-name'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=name;});
  ['set-av-display','s-av','prof-av-btn'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=name.charAt(0).toUpperCase();});
  showToast('✅','Profile Saved','Your display name has been updated.');
}

function setAccent(main,light,el){
  document.querySelectorAll('.accent-sw').forEach(s=>s.classList.remove('on'));el.classList.add('on');
  document.documentElement.style.setProperty('--accent',main);
  document.documentElement.style.setProperty('--al',light);
  savePref('accent',main);savePref('accent_light',light);
  showToast('🎨','Accent Updated','');
}

// ── FONT SIZE ─────────────────────────────────────────────────────
function setFontSize(val){
  document.documentElement.style.setProperty('--ui-font-size', val+'px');
  const prev = document.getElementById('font-size-preview');
  if(prev) prev.textContent = val+'px';
  savePref('font_size', parseInt(val));
}

// ── BORDER RADIUS ─────────────────────────────────────────────────
function setRadius(mode, el){
  document.querySelectorAll('.radius-chip').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  const R={sharp:'2px', default:'13px', pill:'20px'};
  document.documentElement.style.setProperty('--card-radius', R[mode]||R.default);
  savePref('radius', mode);
  showToast('✦','Corner Style Updated', '');
}

// ── SIDEBAR WIDTH ─────────────────────────────────────────────────
function setSidebarWidth(mode, el){
  document.querySelectorAll('.sw-chip').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  const W={slim:'180px', normal:'220px', wide:'260px'};
  document.documentElement.style.setProperty('--sw', W[mode]||W.normal);
  savePref('sidebar_width', mode);
}

// ── REDUCE MOTION ─────────────────────────────────────────────────
function applyReduceMotion(on){
  if(on){
    let s = document.getElementById('_reduce-motion-style');
    if(!s){ s=document.createElement('style'); s.id='_reduce-motion-style'; document.head.appendChild(s); }
    s.textContent='*{animation-duration:0.001ms!important;transition-duration:0.001ms!important;}';
  } else {
    const s=document.getElementById('_reduce-motion-style');
    if(s) s.remove();
  }
}

// ── SESSION / TRADING ─────────────────────────────────────────────
function setSession(sess, el){
  document.querySelectorAll('.sess-chip[data-sess]').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  savePref('preferred_session', sess);
  showToast('📈','Session Updated', sess==='none'?'No session highlight set.':'Preferred session saved.');
}

function setDefaultTF(tf, el){
  document.querySelectorAll('#default-tf-row .sess-chip').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  savePref('default_timeframe', tf);
}

function saveTradingSettings(){
  const fields=[
    ['account-size-inp','account_size'],
    ['max-risk-inp','max_risk_pct'],
    ['daily-target-inp','daily_target'],
    ['daily-loss-inp','daily_loss_limit'],
    ['wr-target-inp','wr_target'],
  ];
  fields.forEach(([id,key])=>{
    const el=document.getElementById(id);
    if(el&&el.value) savePref(key, el.value);
  });
  showToast('✅','Trading Settings Saved','Your goals and risk settings have been updated.');
}

// ── QUIET HOURS ───────────────────────────────────────────────────
function toggleQuietHours(on){
  savePref('quiet_hours', on);
  const w=document.getElementById('quiet-hours-wrap');
  if(w) w.style.display = on ? 'block' : 'none';
}

function setTheme(name,el){
  document.querySelectorAll('.theme-chip').forEach(c=>c.classList.remove('on'));el.classList.add('on');
  const T={dark:{bg:'#04080f',bg2:'#080e1a',bg3:'#0c1525'},deep:{bg:'#020810',bg2:'#050c1a',bg3:'#091020'},slate:{bg:'#0d1117',bg2:'#161b22',bg3:'#21262d'}};
  const t=T[name]||T.dark;
  document.documentElement.style.setProperty('--bg',t.bg);
  document.documentElement.style.setProperty('--bg2',t.bg2);
  document.documentElement.style.setProperty('--bg3',t.bg3);
  savePref('theme',name);
}

// ── DASHBOARD CUSTOMIZATION LOGIC ────────────────────────────────
function setDefaultPage(page,el){
  document.querySelectorAll('.page-chip').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  savePref('default_page',page);
}

function setLayout(layout,el){
  document.querySelectorAll('.layout-card').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  savePref('card_layout',layout);
}

function setChartStyle(style,el){
  document.querySelectorAll('.cs-card').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  savePref('chart_style',style);
}

function setDensity(density,el){
  document.querySelectorAll('.density-chip').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  savePref('density',density);
  // Apply density to root immediately as a preview
  const D={compact:'0.75rem',default:'1.1rem',relaxed:'1.6rem'};
  document.documentElement.style.setProperty('--row-gap', D[density]||D.default);
}

function saveDashboardSettings(){
  // All individual settings already auto-save via savePref; this is just confirmation
  const msg=document.getElementById('dash-saved-msg');
  msg.innerHTML='<span class="saved-flash">✓ Saved</span>';
  msg.style.display='inline-flex';
  setTimeout(()=>{msg.style.display='none';},2500);
  showToast('🖥','Dashboard Settings Saved','Your preferences have been applied.');
}

async function handleNotifToggle(checked){
  if(checked){
    const g=await(async()=>{if(!('Notification'in window))return false;if(Notification.permission==='granted')return true;if(Notification.permission==='denied')return false;return(await Notification.requestPermission())==='granted';})();
    if(!g){document.getElementById('tog-notif-main').checked=false;showToast('⚠️','Permission Denied','Allow notifications in your browser settings.');}
    else{localStorage.setItem('tren_notif','true');showToast('🔔','Notifications On','');}
  }else{localStorage.setItem('tren_notif','false');showToast('🔕','Notifications Off','');}
}

function exportCSV(){
  const trades=getTrades();if(!trades.length){showToast('⚠️','No Data','No trades to export yet.');return;}
  const h=['Date','Pair','Direction','Entry','Exit','Size','P&L','Session','Notes'];
  const r=trades.map(t=>[t.date,t.pair,t.dir,t.entry,t.exit,t.size,t.pnl,t.session,'"'+(t.notes||'').replace(/"/g,"''")+'"'].join(','));
  dlFile([h.join(','),...r].join('\n'),'tren-journal.csv','text/csv');
  showToast('📥','Exported','Downloaded as CSV.');
}
function exportJSON(){
  dlFile(JSON.stringify(getTrades(),null,2),'tren-journal.json','application/json');
  showToast('📥','Exported','Downloaded as JSON.');
}
function importJSON(input){
  const file=input.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      const data=JSON.parse(e.target.result);
      if(!Array.isArray(data))throw new Error('Invalid');
      if(!confirm(`Import ${data.length} trades? This will REPLACE your current journal.`))return;
      localStorage.setItem('tren_journal',JSON.stringify(data));
      showToast('✅','Import Complete',`${data.length} trades restored.`);
      initStats();
    }catch(err){showToast('❌','Import Failed','Invalid file format.');}
  };
  reader.readAsText(file);input.value='';
}
function clearJournal(){
  if(!confirm('Delete ALL journal trades? This is permanent and cannot be undone.'))return;
  localStorage.removeItem('tren_journal');
  showToast('🗑️','Journal Cleared','All trade data has been deleted.');
  initStats();
}
function clearHiddenTrades(){
  localStorage.removeItem('tren_hidden_live');
  showToast('✅','Restored','Hidden live trades will reappear on the Live Signals page.');
}
function resetSettings(){
  if(!confirm('Reset all settings to defaults? Your journal will NOT be affected.'))return;
  localStorage.removeItem('tren_prefs');
  document.documentElement.removeAttribute('style');
  showToast('🔄','Settings Reset','');
  setTimeout(()=>{initToggles();},300);
}

// ── INIT ──────────────────────────────────────────────────────────
initUserInfo();
initSubUI();
initStats();
initToggles();

function goToDashboard(e){
  e.preventDefault();
  window.location.href=localStorage.getItem('tren_session')?'/overview':'/login-page';
}
</script>

<script>let _navLock = false;
function navTo(url){
  if(_navLock)return;
  _navLock=true;
  setTimeout(()=>{_navLock=false;},800);
  try{
    const s=localStorage.getItem('tren_session');
    if(s){ const encoded=encodeURIComponent(btoa(s)); url+=(url.includes('?')?'&':'?')+'_t='+encoded; }
  }catch(e){}
  window.location.href=url;
}</script>
</body>
</html>
