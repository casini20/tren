      </a>

      <div class="s-divider"></div>
      <div class="s-section-label">Tools</div>
      <a class="s-item ai-item" onclick="navTo('https://trenai.vercel.app/ai-analysis')">
        <span class="s-ic">✨</span><span>AI Analysis</span>
        <span class="s-beta">BETA</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/trenbot')">
        <span class="s-ic">🤖</span><span>TrenBot</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/autosignals')">
        <span class="s-ic">⚡</span><span>AutoSignals</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/indicator')">
        <span class="s-ic">📈</span><span>Indicator</span>
      </a>

      <div class="s-divider"></div>
      <div class="s-section-label">Misc</div>
      <a class="s-item gold" onclick="navTo('https://trenai.vercel.app/upgrade')">
        <span class="s-ic">👑</span><span>Upgrade</span>
        <span class="s-badge">PRO</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/settings')">
        <span class="s-ic">⚙️</span><span>Settings</span>
      </a>
    </div>

    <div class="s-bot">
      <a class="u-row" onclick="navTo('https://trenai.vercel.app/settings')">
        <div class="u-av" id="s-av">T</div>
        <div class="u-info">
          <div class="u-name" id="s-nm">Trader</div>
          <div class="u-email" id="s-email-display">—</div>
          <span class="sub-status-badge trial" id="sidebar-plan-badge">⚡ Trial</span>
        </div>
      </a>
      <div class="s-logout" onclick="doLogout()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sign out
      </div>
    </div>
  </nav>

  <!-- MAIN -->
  <div class="main-wrap">

    <!-- TOPBAR -->
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;">
        <button class="mobile-toggle" onclick="toggleSidebar()">☰</button>
        <div>
          <div class="tb-title">Live Signals</div>
          <div style="font-size:12px;color:var(--sub);margin-top:2px;"><span class="live-dot-page"></span>Real-time signals</div>
        </div>
      </div>
      <div class="tb-right">
        <div class="t-pill" id="trial-pill">⏱ <span id="pill-days">7</span> days left in trial</div>
        <button class="nb" id="notif-btn" onclick="toggleNotifications()" title="Toggle notifications">🔔</button>
        <button class="clr-btn" onclick="clearLiveTrades()" title="Clear all from view">Clear View</button>
        <div class="prof-wrap">
          <div class="prof-av" id="prof-av-btn" onclick="toggleProfileMenu()">T</div>
          <div class="prof-menu" id="prof-menu">
            <div class="prof-menu-header">
              <div class="prof-menu-name" id="prof-menu-name">Trader</div>
              <div class="prof-menu-email" id="prof-menu-email">—</div>
            </div>
            <a class="prof-menu-item" onclick="navTo('https://trenai.vercel.app/settings')">👤 Profile settings</a>
            <div class="prof-menu-item danger" onclick="doLogout()">→ Sign out</div>
          </div>
        </div>
      </div>
    </div>

    <!-- PAGE -->
    <div class="page">

      <!-- Stats Strip -->
      <div class="stats-strip">
        <div class="stat-card">
          <div class="stat-label">Active Signals</div>
          <div class="stat-value" id="stat-active">—</div>
          <div class="stat-sub">Live now</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Long</div>
          <div class="stat-value green" id="stat-longs">—</div>
          <div class="stat-sub">Bullish</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Short</div>
          <div class="stat-value red" id="stat-shorts">—</div>
          <div class="stat-sub">Bearish</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Live P&amp;L</div>
          <div class="stat-value" id="stat-pnl">—</div>
          <div class="stat-sub">Open trades</div>
        </div>
      </div>

      <!-- Filter + Sort Bar -->
      <div class="filter-bar">
        <button class="filter-tab on" data-f="all" onclick="setFilter('all')">All</button>
        <button class="filter-tab f-long" data-f="long" onclick="setFilter('long')">▲ Long</button>
        <button class="filter-tab f-short" data-f="short" onclick="setFilter('short')">▼ Short</button>
        <button class="filter-tab" data-f="active" onclick="setFilter('active')">Active</button>
        <button class="filter-tab" data-f="closed" onclick="setFilter('closed')">Closed</button>
        <div class="filter-spacer"></div>
        <div style="display:flex;align-items:center;gap:6px;font-size:11.5px;color:var(--sub);">
          <span class="live-dot-page" style="width:7px;height:7px;margin-right:2px;"></span>
          Refreshes in <strong id="refresh-counter" style="color:var(--sub2);min-width:20px;display:inline-block;">1s</strong>
        </div>
      </div>

      <!-- Empty state -->
      <div id="live-empty" style="text-align:center;padding:4rem 2rem;color:var(--sub);display:none;">
        <div style="font-size:52px;margin-bottom:1rem;opacity:.6">📡</div>
        <div style="font-size:17px;font-weight:700;margin-bottom:.5rem;color:var(--sub2);">No signals right now</div>
        <div style="font-size:12.5px;line-height:1.7;max-width:340px;margin:0 auto;color:var(--sub);">New signals appear here automatically.<br>Refreshing every 1 second.</div>
      </div>

      <div class="live-grid" id="live-grid"></div>

    </div>

  </div>
</div>

<script>
// ── SESSION RECOVERY (runs before anything else) ──────────────────
(function(){
  try{
    const p=new URLSearchParams(window.location.search);
    const t=p.get('_t');
    if(t){
      const existing=localStorage.getItem('tren_session');
      if(!existing){
        const decoded=JSON.parse(atob(decodeURIComponent(t)));
        localStorage.setItem('tren_session',JSON.stringify(decoded));
      }
      window.history.replaceState({},'',window.location.pathname);
    }
  }catch(e){}
})();

// ── CORE ──────────────────────────────────────────────────────────
const SUPABASE_AUTH_URL='https://sjntsmzbiqvtstvofcnx.supabase.co';
const SUPABASE_AUTH_KEY='sb_publishable_n0q0FsM9hZARXxKKIDprFw_O6GJfRAg';
const SUPABASE_URL='https://rjzteejovzmytfeupeaa.supabase.co';
const SUPABASE_KEY='sb_publishable_p0W2wgXC1zc73-50mSx2ew_OBOCMSXJ';
const SESSION_KEY='tren_session';

// ── NAV WITH SESSION PASSTHROUGH ─────────────────────────────────
function navTo(url){
  try{
    const s=localStorage.getItem(SESSION_KEY);
    if(s){
      const encoded=encodeURIComponent(btoa(s));
      url+=(url.includes('?')?'&':'?')+'_t='+encoded;
    }
  }catch(e){}
  window.location.href=url;
}

let _session=window.__trenSession||(()=>{try{const r=localStorage.getItem(SESSION_KEY);return r?JSON.parse(r):null;}catch{return null;}})();
if(!(_session&&_session.access_token)){window.location.href='https://trenai.vercel.app/login-page';}

let _subData=null,_autoSubData=null,_autoSignalsSubData=null;
try{_subData=JSON.parse(localStorage.getItem('tren_sub')||'null');}catch(e){}
try{_autoSubData=JSON.parse(localStorage.getItem('tren_trenbot_sub')||'null');}catch(e){}
try{_autoSignalsSubData=JSON.parse(localStorage.getItem('tren_autosignals_sub')||'null');}catch(e){}

function getSessionEmail(){return _session&&_session.user&&_session.user.email?_session.user.email:'—';}
function getSessionFullName(){if(_session&&_session.user){const m=_session.user.user_metadata||{};if(m.full_name)return m.full_name;if(m.name)return m.name;if(_session.user.email)return _session.user.email.split('@')[0].replace(/[._]/g,' ').replace(/\b\w/g,c=>c.toUpperCase());}return'Trader';}
function getPrefs(){return JSON.parse(localStorage.getItem('tren_prefs')||'{}');}
function getUserDisplayName(){const e=getSessionEmail(),p=getPrefs(),u=p.display_names||{};return u[e]||getSessionFullName();}
function escHtml(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function fmtNum(n,d){return Number(n).toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d});}
function fmtDate(iso){const d=new Date(iso),now=new Date();const dm=Math.floor((now-d)/60000);if(dm<60)return dm<=1?'just now':`${dm}m ago`;const dh=Math.floor(dm/60);if(dh<24)return`${dh}h ago`;return d.toLocaleDateString('en-GB',{day:'numeric',month:'short'});}
function getUserTimezone(){return Intl.DateTimeFormat().resolvedOptions().timeZone;}
async function sbFetch(path){const res=await fetch(`${SUPABASE_URL}/rest/v1/${path}`,{headers:{'apikey':SUPABASE_KEY}});if(!res.ok)throw new Error(res.status);return res.json();}
function showToast(icon,title,msg){const ex=document.querySelector('.toast');if(ex)ex.remove();const t=document.createElement('div');t.className='toast';t.innerHTML=`<div class="toast-icon">${icon}</div><div class="toast-body"><div class="toast-title">${escHtml(title)}</div><div class="toast-msg">${escHtml(msg)}</div></div><button class="toast-close" onclick="this.parentElement.remove()">✕</button>`;document.body.appendChild(t);setTimeout(()=>{if(t.parentElement)t.remove();},5000);}

async function doLogout(){
  const tok=_session?_session.access_token:'';
  localStorage.removeItem(SESSION_KEY);
  ['tren_sub','tren_prefs','tren_auto_sub','tren_autosignals_sub','tren_trenbot_sub'].forEach(k=>localStorage.removeItem(k));
  try{fetch(`${SUPABASE_AUTH_URL}/auth/v1/logout`,{method:'POST',headers:{'apikey':SUPABASE_AUTH_KEY,'Authorization':'Bearer '+tok}}).catch(()=>{});}catch(e){}
  window.location.href='https://trenai.vercel.app/login-page';
}

function initUserInfo(){
  const name=getUserDisplayName(),email=getSessionEmail(),init=name.charAt(0).toUpperCase();
  ['s-nm','prof-menu-name'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=name;});
  ['s-av','prof-av-btn'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=init;});
  const se=document.getElementById('s-email-display');if(se)se.textContent=email;
  const pe=document.getElementById('prof-menu-email');if(pe)pe.textContent=email;
}

function initSubUI(){
  const hasTB=_autoSubData?.status==='active'&&_autoSubData?.plan==='trenbot';
  const hasAS=_autoSignalsSubData?.status==='active'&&_autoSignalsSubData?.plan==='auto';
  const hasP=_subData?.status&&_subData.status!=='inactive'&&_subData.status!=='cancelled';
  const tc=document.getElementById('trial-card');
  const tp=document.getElementById('trial-pill');
  const sb=document.getElementById('sidebar-plan-badge');
  if(hasTB||hasAS||hasP){
    if(tc)tc.style.display='none';
    let lbl='⚡ Premium',cls='premium';
    if(hasTB){lbl='⚡ TrenBot';cls='automated';}
    else if(hasAS){lbl='⚡ AutoSignals';cls='autosignals';}
    if(tp){tp.textContent=lbl+' Active';tp.className='t-pill '+cls;}
    if(sb){sb.textContent=lbl;sb.className='sub-status-badge '+cls;}
  }
}

function toggleProfileMenu(){
  const m=document.getElementById('prof-menu'),b=document.getElementById('prof-av-btn');
  const o=m.classList.contains('open');
  m.classList.toggle('open',!o);b.classList.toggle('open',!o);
}
document.addEventListener('click',e=>{
  const pw=document.querySelector('.prof-wrap');
  if(pw&&!pw.contains(e.target)){document.getElementById('prof-menu').classList.remove('open');document.getElementById('prof-av-btn').classList.remove('open');}
  const sb=document.getElementById('sidebar'),ov=document.getElementById('sb-overlay');
  if(window.innerWidth<=850&&sb.classList.contains('open')&&!sb.contains(e.target)&&!document.querySelector('.mobile-toggle').contains(e.target)){closeSidebar();}
});
function toggleSidebar(){document.getElementById('sidebar').classList.toggle('open');document.getElementById('sb-overlay').classList.toggle('open');}
function closeSidebar(){document.getElementById('sidebar').classList.remove('open');document.getElementById('sb-overlay').classList.remove('open');}

// ── NOTIFICATIONS ─────────────────────────────────────────────────
let notifEnabled=localStorage.getItem('tren_notif')==='true';
async function requestNotifPermission(){if(!('Notification'in window))return false;if(Notification.permission==='granted')return true;if(Notification.permission==='denied')return false;return(await Notification.requestPermission())==='granted';}
function sendNotif(title,body){if(!notifEnabled||Notification.permission!=='granted')return;new Notification(title,{body,tag:'tren-trade',requireInteraction:true});}
function toggleNotifications(){
  const btn=document.getElementById('notif-btn');
  if(!notifEnabled){requestNotifPermission().then(g=>{if(g){notifEnabled=true;localStorage.setItem('tren_notif','true');btn.classList.add('on');showToast('🔔','Notifications Enabled','You will receive alerts when new trades are entered.');}else{showToast('⚠️','Permission Denied','Allow notifications in your browser settings.');}});}
  else{notifEnabled=false;localStorage.setItem('tren_notif','false');btn.classList.remove('on');showToast('🔕','Notifications Disabled','');}
}

// ── LIVE LOGIC ────────────────────────────────────────────────────
let liveLastSeenIds=new Set();
let activeFilter='all';
let refreshCountdown=10;

function parseBool(v){if(v===true||v===1||v==='1')return true;if(typeof v==='string'){const l=v.toLowerCase().trim();if(l==='true'||l==='t'||l==='yes')return true;}return false;}
function isTradeExpired(ts){if(!ts)return true;return(Date.now()-new Date(ts).getTime())>24*60*60*1000;}

function calcRisk(t){
  const entry=parseFloat(t.entry),sl=parseFloat(t.stop_loss),qty=parseInt(t.quantity)||1;
  if(!entry||!sl||isNaN(entry)||isNaN(sl))return{riskPts:null,riskDollar:null,rr1:null,rr2:null};
  const riskPts=Math.abs(entry-sl);
  const riskDollar=riskPts*20*qty;
  const tp3=parseFloat(t.tp3);
  const rr1=tp3&&!isNaN(tp3)?(Math.abs(tp3-entry)/riskPts).toFixed(1):null;
  return{riskPts:riskPts.toFixed(1),riskDollar:Math.round(riskDollar),rr1};
}

function getSession(ts){
  if(!ts)return null;
  try{
    const d=new Date(ts);
    const ny=new Date(d.toLocaleString('en-US',{timeZone:'America/New_York'}));
    const h=ny.getHours();
    if(h>=9&&h<12)return{label:'NY Open',bg:'rgba(59,130,246,.14)',color:'#60a5fa'};
    if(h>=12&&h<16)return{label:'Afternoon',bg:'rgba(139,92,246,.14)',color:'#a78bfa'};
    if(h>=3&&h<9)return{label:'London',bg:'rgba(245,158,11,.14)',color:'#fbbf24'};
    return{label:'Overnight',bg:'rgba(255,255,255,.06)',color:'rgba(240,244,255,.35)'};
  }catch(e){return null;}
}

function getProgressWidth(t1,t2,t3,sh){
  if(sh)return 0;
  if(t3)return 100;
  if(t2)return 66;
  if(t1)return 33;
  return 0;
}
function getProgressLabel(t1,t2,t3,sh){
  if(sh)return'Stop hit';
  if(t3)return'3/3 targets ✓';
  if(t2)return'2/3 targets';
  if(t1)return'1/3 targets';
  return'Watching';
}

function copyTrade(id){
  const card=document.querySelector(`.live-card[data-id="${id}"]`);
  if(!card)return;
  const e=card.dataset.entry,sl=card.dataset.sl,tp1=card.dataset.tp1,tp2=card.dataset.tp2,tp3=card.dataset.tp3,dir=card.dataset.dir?.toUpperCase();
  const text=`${dir} NQ Future\nEntry: ${e}\nStop Loss: ${sl}\nTP1: ${tp1} | TP2: ${tp2} | TP3: ${tp3}`;
  navigator.clipboard.writeText(text).then(()=>showToast('⎘','Copied','Trade details copied to clipboard.')).catch(()=>showToast('⚠️','Failed','Could not copy to clipboard.'));
}

function setFilter(f){
  activeFilter=f;
  document.querySelectorAll('.filter-tab').forEach(t=>t.classList.toggle('on',t.dataset.f===f));
  document.querySelectorAll('#live-grid .live-card').forEach(card=>{
    let show=true;
    if(f==='long')show=card.classList.contains('long');
    if(f==='short')show=card.classList.contains('short');
    if(f==='active')show=!card.classList.contains('closed');
    if(f==='closed')show=card.classList.contains('closed');
    card.style.display=show?'':'none';
  });
  const grid=document.getElementById('live-grid');
  const anyVisible=Array.from(grid.children).some(c=>c.style.display!=='none');
  document.getElementById('live-empty').style.display=(!anyVisible&&grid.children.length>0)?'block':'none';
  updateStats();
}

function updateStats(){
  const cards=Array.from(document.querySelectorAll('#live-grid .live-card'));
  const active=cards.filter(c=>!c.classList.contains('closed')).length;
  const longs=cards.filter(c=>c.classList.contains('long')&&!c.classList.contains('closed')).length;
  const shorts=cards.filter(c=>c.classList.contains('short')&&!c.classList.contains('closed')).length;
  let totalPnl=0;let hasPnl=false;
  cards.forEach(c=>{const p=parseFloat(c.dataset.pnl||'');if(!isNaN(p)){totalPnl+=p;hasPnl=true;}});
  const setEl=(id,v)=>{const el=document.getElementById(id);if(el)el.textContent=v;};
  setEl('stat-active',active);
  setEl('stat-longs',longs);
  setEl('stat-shorts',shorts);
  const pnlEl=document.getElementById('stat-pnl');
  if(pnlEl){
    if(hasPnl){
      pnlEl.textContent=(totalPnl>=0?'+$':'−$')+Math.abs(totalPnl).toFixed(0);
      pnlEl.className='stat-value '+(totalPnl>=0?'green':'red');
    }else{pnlEl.textContent='—';pnlEl.className='stat-value';}
  }
}

function buildLiveCard(t){
  const isS=(t.direction||'').toLowerCase()==='short';
  const isN=Date.now()-new Date(t.timestamp).getTime()<30000;
  const t1=parseBool(t.tp1_hit),t2=parseBool(t.tp2_hit),t3=parseBool(t.tp3_hit),sh=parseBool(t.stop_hit);
  const status=t.status||'active';
  let sc=status,st=sc==='active'?'● Active':'Closed';
  if(t1&&!t2&&!sh){sc='tp1';st='TP1 Hit';}
  if(t2&&!t3&&!sh){sc='tp2';st='TP2 Hit';}
  if(t3){sc='tp3';st='TP3 Hit ✓';}
  if(sh){sc='stop';st='Stop Loss';}
  const iC=status==='closed'||sh||t3;
  const dirC=isS?'short':'long';
  const risk=calcRisk(t);
  const sess=getSession(t.timestamp);
  const pw=getProgressWidth(t1,t2,t3,sh);
  const pl=getProgressLabel(t1,t2,t3,sh);
  const pnlVal=t.pnl_live?parseFloat(t.pnl_live):null;
  // Expiry
  let expiryH='';
  if(iC&&t.timestamp){
    const ms=(new Date(t.timestamp).getTime()+86400000)-Date.now();
    if(ms>0){
      const hl=Math.floor(ms/3600000),ml=Math.floor((ms%3600000)/60000);
      const ts=hl>0?`${hl}h ${ml}m`:`${ml}m`;
      expiryH=`<div class="lc-expiry"><span style="font-size:11px">🕐</span><span class="lc-expiry-text">Removed in <strong>${ts}</strong></span></div>`;
    }
  }
  // Risk chips
  let riskChipsH='';
  if(risk.riskDollar||risk.rr1){
    riskChipsH=`<div class="lc-risk-row">
      ${risk.riskDollar?`<div class="lc-risk-chip"><span class="rchip-lbl">Risk /trade</span><span class="rchip-val risk">$${risk.riskDollar.toLocaleString()}</span></div>`:''}
      ${risk.riskPts?`<div class="lc-risk-chip"><span class="rchip-lbl">Risk pts</span><span class="rchip-val neutral">${risk.riskPts} pts</span></div>`:''}
      ${risk.rr1?`<div class="lc-risk-chip"><span class="rchip-lbl">R:R (TP3)</span><span class="rchip-val reward">1:${risk.rr1}</span></div>`:''}
    </div>`;
  }
  const sessH=sess?`<span class="lc-session" style="background:${sess.bg};color:${sess.color}">${sess.label}</span>`:'';
  return`<div class="live-card ${dirC} ${iC?'closed':''}" data-id="${t.id}" data-dir="${dirC}" data-entry="${t.entry||''}" data-sl="${t.stop_loss||''}" data-tp1="${t.tp1||''}" data-tp2="${t.tp2||''}" data-tp3="${t.tp3||''}" data-pnl="${pnlVal!==null?pnlVal:''}">
    <div class="lc-sidebar"></div>
    ${isN?`<div class="lc-new-badge">NEW</div>`:''}
    <div class="lc-body">
      <div class="lc-header">
        <div class="lc-header-left">
          <div class="lc-dir-badge ${dirC}"><span class="dir-arrow">${isS?'▼':'▲'}</span>${isS?'SHORT':'LONG'}</div>
          <div class="lc-pair">${escHtml(t.pair||t.market||'—')}</div>
        </div>
        <div class="lc-header-right">
          <div class="live-status ${sc}">${st}</div>
        </div>
      </div>
      <div class="lc-meta">
        <span class="lc-time">${fmtDate(t.timestamp)}</span>
        ${sessH?`<span class="lc-dot-sep"></span>${sessH}`:''}
        <span class="lc-dot-sep"></span>
        <span class="lc-time">${getUserTimezone()}</span>
      </div>
      <div class="lc-levels">
        <div class="lc-level">
          <div class="lc-level-lbl">Entry Price</div>
          <div class="lc-level-val entry">${fmtNum(t.entry,2)}</div>
        </div>
        <div class="lc-level-sep">→</div>
        <div class="lc-level right">
          <div class="lc-level-lbl">Stop Loss</div>
          <div class="lc-level-val stop">${fmtNum(t.stop_loss,2)}</div>
          <div style="font-size:9px;color:var(--sub);margin-top:2px;line-height:1.3;">on candle close beyond level</div>
        </div>
      </div>
      ${riskChipsH}
      <div class="lc-tps">
        <div class="live-tp ${t1?'filled':''} ${sh&&!t1?'stop-hit':''}"><span class="tp-lbl">TP1</span><span class="tp-num">${fmtNum(t.tp1,2)}</span></div>
        <div class="live-tp ${t2?'filled':''} ${sh&&!t2?'stop-hit':''}"><span class="tp-lbl">TP2</span><span class="tp-num">${fmtNum(t.tp2,2)}</span></div>
        <div class="live-tp ${t3?'filled':''} ${sh&&!t3?'stop-hit':''}"><span class="tp-lbl">TP3</span><span class="tp-num">${fmtNum(t.tp3,2)}</span></div>
      </div>
      <div class="lc-progress">
        <div class="lc-progress-track"><div class="lc-progress-fill" style="width:${pw}%"></div></div>
        <span class="lc-progress-label">${pl}</span>
      </div>
      <div class="lc-footer">
        <span class="lc-qty">📊 ${t.quantity||3} contracts</span>
        ${pnlVal!==null?`<div class="lc-pnl ${pnlVal>=0?'pos':'neg'}">${pnlVal>=0?'+':''}$${Math.abs(pnlVal).toFixed(2)}</div>`:''}
        <button class="lc-copy-btn" onclick="copyTrade('${t.id}')" title="Copy trade details">⎘</button>
      </div>
      ${expiryH}
    </div>
  </div>`;
}

async function loadLiveTrades(){
  const grid=document.getElementById('live-grid'),empty=document.getElementById('live-empty');
  try{
    const data=await sbFetch('live_trades?order=timestamp.desc&limit=20');
    const fresh=data.filter(t=>!isTradeExpired(t.timestamp));
    const hidden=new Set(JSON.parse(localStorage.getItem('tren_hidden_live')||'[]'));
    const visible=fresh.filter(t=>!hidden.has(t.id));
    const curIds=new Set(visible.map(t=>String(t.id)));
    const newT=visible.filter(t=>!liveLastSeenIds.has(String(t.id)));
    if(newT.length>0&&liveLastSeenIds.size>0)newT.forEach(t=>sendNotif('New Trade',`Entry: ${t.entry} | Stop: ${t.stop_loss} | TP1: ${t.tp1}`));
    liveLastSeenIds=curIds;
    if(!visible.length){grid.innerHTML='';empty.style.display='block';return;}
    empty.style.display='none';
    const existing=new Set(Array.from(grid.children).map(el=>el.dataset.id));
    visible.forEach(t=>{
      const tid=String(t.id);
      if(!existing.has(tid)){
        const card=document.createElement('div');card.innerHTML=buildLiveCard(t);
        if(card.firstElementChild)grid.appendChild(card.firstElementChild);
      } else {
        const ec=grid.querySelector(`[data-id="${tid}"]`);if(!ec)return;
        const t1=parseBool(t.tp1_hit),t2=parseBool(t.tp2_hit),t3=parseBool(t.tp3_hit),sh=parseBool(t.stop_hit);
        const tps=ec.querySelectorAll('.live-tp');
        if(tps[0]){tps[0].classList.toggle('filled',t1);tps[0].classList.toggle('stop-hit',sh&&!t1);}
        if(tps[1]){tps[1].classList.toggle('filled',t2);tps[1].classList.toggle('stop-hit',sh&&!t2);}
        if(tps[2]){tps[2].classList.toggle('filled',t3);tps[2].classList.toggle('stop-hit',sh&&!t3);}
        const se=ec.querySelector('.live-status');
        if(se){let sc=t.status||'active',st=sc==='active'?'● Active':'Closed';if(t1&&!t2&&!sh){sc='tp1';st='TP1 Hit';}if(t2&&!t3&&!sh){sc='tp2';st='TP2 Hit';}if(t3){sc='tp3';st='TP3 Hit ✓';}if(sh){sc='stop';st='Stop Loss';}se.className='live-status '+sc;se.textContent=st;}
        const iC=t.status==='closed'||parseBool(t.stop_hit)||parseBool(t.tp3_hit);ec.classList.toggle('closed',iC);
      }
    });
    Array.from(grid.children).forEach(el=>{if(!curIds.has(el.dataset.id))el.remove();});
  }catch(e){console.error('Live trades error:',e);}
}

function clearLiveTrades(){
  if(!confirm('Clear all live trades from view?'))return;
  const grid=document.getElementById('live-grid');
  let hidden=JSON.parse(localStorage.getItem('tren_hidden_live')||'[]');
  Array.from(grid.children).forEach(c=>{const id=c.dataset.id;if(id&&!hidden.includes(id))hidden.push(id);});
  localStorage.setItem('tren_hidden_live',JSON.stringify(hidden));
  grid.innerHTML='';document.getElementById('live-empty').style.display='block';liveLastSeenIds.clear();
  showToast('🗑️','Cleared','Live trades cleared from view.');
}

// ── INIT ──────────────────────────────────────────────────────────
initUserInfo();
initSubUI();
if(notifEnabled&&typeof Notification!=='undefined'&&Notification.permission==='granted'){
  document.getElementById('notif-btn').classList.add('on');
}
// Auto-clear hidden list after 24h
const lhc=localStorage.getItem('tren_hidden_cleared');
if(!lhc||(Date.now()-parseInt(lhc))>86400000){
  localStorage.removeItem('tren_hidden_live');
  localStorage.setItem('tren_hidden_cleared',String(Date.now()));
}
loadLiveTrades();
setInterval(loadLiveTrades,10000);
</script>
<script>
  function goToDashboard(e) {
    e.preventDefault();
    if (localStorage.getItem('tren_session')) {
      window.location.href = '/overview';
    } else {
      window.location.href = '/login-page';
    }
  }
</script>
</body>
</html>
