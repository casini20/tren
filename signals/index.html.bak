<!DOCTYPE html>
<html lang="en">
<head>


<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Tren – Recent Trades</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="prefetch" href="#" onclick="goToDashboard(event)">
<link rel="prefetch" href="https://trenai.vercel.app/live-signals">
<link rel="prefetch" href="https://trenai.vercel.app/journal">
<link rel="prefetch" href="https://trenai.vercel.app/settings">
<link rel="prefetch" href="https://trenai.vercel.app/upgrade">
<link rel="prefetch" href="https://trenai.vercel.app/trenbot">
<link rel="prefetch" href="https://trenai.vercel.app/autosignals">
<link rel="prefetch" href="https://trenai.vercel.app/indicator">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;height:100%;background:#04080f;overflow:hidden;}
:root{
  --bg:#04080f;--bg2:#080e1a;--bg3:#0c1525;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);
  --accent:#2563eb;--al:#3b82f6;--green:#10b981;--red:#ef4444;--gold:#f59e0b;
  --text:#f0f4ff;--sub:rgba(240,244,255,0.45);--sub2:rgba(240,244,255,0.72);
  --sw:220px;
}

/* ── LAYOUT ── */
.shell{position:fixed;inset:0;display:flex;font-family:'Plus Jakarta Sans',sans-serif;color:var(--text);background:var(--bg);}

/* ── SIDEBAR ── */
.sidebar{width:var(--sw);min-width:var(--sw);height:100vh;border-right:1px solid var(--border);background:#060b14;display:flex;flex-direction:column;padding:0;position:relative;z-index:20;overflow-y:auto;overflow-x:hidden;scrollbar-width:none;}
.sidebar::-webkit-scrollbar{display:none;}
.s-logo{font-size:17px;font-weight:600;padding:22px 18px 18px;display:flex;align-items:center;gap:9px;text-decoration:none;color:inherit;letter-spacing:-0.4px;}
.s-logo-dot{width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:0 0 0 3px rgba(37,99,235,0.2);flex-shrink:0;}
.s-logo span{color:var(--al);}
.s-section-label{font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(240,244,255,0.18);padding:12px 18px 4px;}
.s-nav{flex:1;display:flex;flex-direction:column;padding:0 10px;gap:1px;}
.s-item{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;font-size:13px;font-weight:500;color:rgba(240,244,255,0.42);cursor:pointer;transition:background .12s,color .12s;text-decoration:none;position:relative;}
.s-item:hover{background:rgba(255,255,255,.04);color:rgba(240,244,255,0.8);}
.s-item.on{background:rgba(37,99,235,.14);color:#e0eaff;}
.s-item.on::before{content:'';position:absolute;left:-6px;top:50%;transform:translateY(-50%);width:3px;height:16px;border-radius:0 3px 3px 0;background:var(--accent);}
.s-item.gold{color:var(--gold);}
.s-item.gold:hover{background:rgba(245,158,11,.06);}
.s-item.ai-item{color:#a78bfa;}
.s-item.ai-item:hover{background:rgba(167,139,250,.07);color:#c4b5fd;}
.s-ic{width:28px;height:28px;border-radius:7px;background:rgba(255,255,255,.04);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:13px;}
.s-item.on .s-ic{background:rgba(37,99,235,.18);}
.s-item.gold .s-ic{background:rgba(245,158,11,.08);}
.s-item.ai-item .s-ic{background:rgba(167,139,250,.1);}
.s-badge{margin-left:auto;font-size:9px;padding:2px 6px;border-radius:4px;font-weight:700;background:var(--gold);color:#000;letter-spacing:.03em;}
.s-beta{margin-left:auto;font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;background:rgba(167,139,250,.15);border:0.5px solid rgba(167,139,250,.3);color:#a78bfa;letter-spacing:.03em;}
.s-divider{height:0.5px;background:rgba(255,255,255,.05);margin:4px 10px;}
.s-bot{padding:10px 10px 14px;flex-shrink:0;border-top:0.5px solid rgba(255,255,255,.05);margin-top:auto;}
.trial-card{display:none;}
.up-mini{width:100%;padding:8px;border:none;border-radius:7px;background:linear-gradient(90deg,var(--accent),var(--al));color:#fff;font-size:11.5px;font-weight:600;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;transition:opacity .15s;}
.up-mini:hover{opacity:.88;}
.u-row{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:9px;cursor:pointer;transition:background .12s;text-decoration:none;border:0.5px solid transparent;}
.u-row:hover{background:rgba(255,255,255,.04);border-color:rgba(255,255,255,.07);}
.u-av{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,var(--accent),var(--al));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;flex-shrink:0;color:#fff;}
.u-info{min-width:0;flex:1;display:flex;flex-direction:column;gap:1px;}
.u-name{font-size:12.5px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.u-email{font-size:10px;color:var(--sub);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sub-status-badge{display:inline-flex;align-items:center;gap:3px;font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;margin-top:3px;letter-spacing:.03em;}
.sub-status-badge.trial{background:rgba(245,158,11,.1);border:0.5px solid rgba(245,158,11,.22);color:var(--gold);}
.sub-status-badge.premium{background:rgba(37,99,235,.12);border:0.5px solid rgba(37,99,235,.28);color:var(--al);}
.sub-status-badge.automated{background:rgba(245,158,11,.1);border:0.5px solid rgba(245,158,11,.22);color:var(--gold);}
.sub-status-badge.autosignals{background:rgba(16,185,129,.12);border:0.5px solid rgba(16,185,129,.28);color:var(--green);}
.s-logout{display:flex;align-items:center;gap:8px;padding:6px 10px;border-radius:7px;font-size:11.5px;font-weight:500;color:rgba(239,68,68,.45);cursor:pointer;transition:all .12s;margin-top:2px;}
.s-logout:hover{background:rgba(239,68,68,.07);color:var(--red);}
.live-dot-nav{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--green);animation:flicker 3.5s infinite;box-shadow:0 0 5px var(--green);}
@keyframes flicker{0%,100%{opacity:1;transform:scale(1);}15%{opacity:.88;transform:scale(.95);}30%{opacity:1;transform:scale(1.03);}45%{opacity:.92;transform:scale(.97);}60%{opacity:1;transform:scale(1.06);}75%{opacity:.9;transform:scale(.94);}90%{opacity:1;transform:scale(1.02);}}

/* ── MAIN AREA ── */
.main-wrap{flex:1;display:flex;flex-direction:column;min-width:0;height:100vh;overflow:hidden;}

/* ── TOPBAR ── */
.topbar{display:flex;align-items:center;justify-content:space-between;padding:1.1rem 2.4rem;border-bottom:1px solid var(--border);background:rgba(4,8,15,.88);backdrop-filter:blur(20px);flex-shrink:0;position:relative;z-index:10;}
.tb-title{font-size:17px;font-weight:700;}
.tb-right{display:flex;align-items:center;gap:11px;}
.t-pill{display:flex;align-items:center;gap:5px;background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.25);color:var(--gold);font-size:11.5px;font-weight:600;padding:5px 13px;border-radius:20px;}
.t-pill.premium{background:rgba(37,99,235,.12);border-color:rgba(37,99,235,.3);color:var(--al);}
.t-pill.autosignals{background:rgba(16,185,129,.12);border-color:rgba(16,185,129,.3);color:var(--green);}
.t-pill.automated{background:rgba(245,158,11,.12);border-color:rgba(245,158,11,.3);color:var(--gold);}
.nb{width:33px;height:33px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px;transition:border-color .2s;}
.nb:hover{border-color:var(--border2);}
.prof-wrap{position:relative;}
.prof-av{width:33px;height:33px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--al));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;cursor:pointer;border:2px solid transparent;transition:border-color .2s;color:#fff;}
.prof-av:hover{border-color:rgba(255,255,255,.2);}
.prof-av.open{border-color:var(--al);}
.prof-menu{position:absolute;top:calc(100% + 10px);right:0;background:linear-gradient(145deg,#0d1628,#080e1a);border:1px solid rgba(255,255,255,.12);border-radius:13px;padding:6px;min-width:190px;z-index:200;box-shadow:0 12px 40px rgba(0,0,0,.55);display:none;}
.prof-menu.open{display:block;animation:pf .2s ease;}
@keyframes pf{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.prof-menu-header{padding:10px 12px;border-bottom:1px solid rgba(255,255,255,.06);margin-bottom:5px;}
.prof-menu-name{font-size:13px;font-weight:700;color:var(--text);}
.prof-menu-email{font-size:11px;color:var(--sub);margin-top:2px;}
.prof-menu-item{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:9px;font-size:13px;font-weight:500;color:var(--sub2);cursor:pointer;transition:all .15s;text-decoration:none;}
.prof-menu-item:hover{background:rgba(255,255,255,.06);color:var(--text);}
.prof-menu-item.danger{color:rgba(239,68,68,.75);}
.prof-menu-item.danger:hover{background:rgba(239,68,68,.09);color:var(--red);}

/* ── PAGE CONTENT ── */
.page{flex:1;overflow-y:auto;padding:1.8rem 2.4rem;scrollbar-width:none;}
.page::-webkit-scrollbar{display:none;}

/* ── SIGNALS ── */
.flt{display:flex;align-items:center;gap:8px;margin-bottom:1.4rem;flex-wrap:wrap;}
.fb{font-size:12px;color:var(--sub2);cursor:pointer;padding:5px 11px;border-radius:8px;border:1px solid var(--border);background:transparent;font-family:'Plus Jakarta Sans',sans-serif;transition:all .18s;}
.fb:hover{border-color:var(--border2);color:var(--text);}
.fb.on{background:rgba(59,130,246,.12);border-color:rgba(59,130,246,.28);color:var(--al);}
.sig-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:13px;}
.sig-card{background:var(--bg3);border:1px solid var(--border);border-radius:13px;padding:1.1rem;transition:border-color .2s,transform .2s;cursor:pointer;position:relative;overflow:hidden;}
.sig-card:hover{border-color:var(--border2);transform:translateY(-2px);}
.sig-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.sig-card.win-border::before{background:linear-gradient(90deg,var(--green),transparent);}
.sig-card.loss-border::before{background:linear-gradient(90deg,var(--red),transparent);}
.sig-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px;}
.sig-pair{font-size:15px;font-weight:700;}
.sig-dir{font-size:10.5px;font-weight:700;padding:3px 9px;border-radius:5px;text-transform:uppercase;letter-spacing:.5px;}
.sig-dir.lng{background:rgba(16,185,129,.15);color:var(--green);border:1px solid rgba(16,185,129,.25);}
.sig-dir.sht{background:rgba(239,68,68,.15);color:var(--red);border:1px solid rgba(239,68,68,.25);}
.sig-meta{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:9px;}
.sig-f label{font-size:10px;color:var(--sub);text-transform:uppercase;letter-spacing:.5px;}
.sig-f p{font-size:12.5px;font-weight:500;margin-top:2px;}
.sig-f p.g{color:var(--green);}
.sig-f p.r{color:var(--red);}
.sig-bw{height:3px;background:rgba(255,255,255,.06);border-radius:2px;margin-bottom:7px;}
.sig-b{height:100%;border-radius:2px;}
.sig-ft{display:flex;align-items:center;justify-content:space-between;}
.sig-tm{font-size:11px;color:var(--sub);}
.sig-st{font-size:11px;padding:2px 8px;border-radius:5px;font-weight:600;}
.sig-st.ac{background:rgba(37,99,235,.15);color:var(--al);}
.sig-st.ht{background:rgba(16,185,129,.15);color:var(--green);}
.sig-st.ls{background:rgba(239,68,68,.12);color:var(--red);}
.sig-pnl-badge{font-size:14px;font-weight:700;}
.sig-pnl-badge.pos{color:var(--green);}
.sig-pnl-badge.neg{color:var(--red);}
.skel{background:rgba(255,255,255,.04);border-radius:8px;animation:sk 1.4s ease infinite;}
@keyframes sk{0%,100%{opacity:.4}50%{opacity:.9}}

/* ── STATS BAR ── */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:1.4rem;}
.stat-card{background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:.9rem 1.1rem;position:relative;overflow:hidden;}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;border-radius:2px 2px 0 0;}
.stat-card.sc-total::before{background:linear-gradient(90deg,var(--al),transparent);}
.stat-card.sc-wr::before{background:linear-gradient(90deg,var(--green),transparent);}
.stat-card.sc-pnl::before{background:linear-gradient(90deg,var(--gold),transparent);}
.stat-card.sc-ticks::before{background:linear-gradient(90deg,#a78bfa,transparent);}
.stat-label{font-size:10px;color:var(--sub);text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px;}
.stat-val{font-size:22px;font-weight:700;letter-spacing:-.3px;}
.stat-sub{font-size:11px;color:var(--sub);margin-top:3px;}
.flt-top{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:.8rem;flex-wrap:wrap;}
.search-wrap{position:relative;flex:1;min-width:160px;max-width:260px;}
.search-input{width:100%;background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:8px;padding:5px 10px 5px 30px;font-size:12px;color:var(--text);font-family:'Plus Jakarta Sans',sans-serif;outline:none;transition:border-color .18s;}
.search-input:focus{border-color:var(--border2);}
.search-input::placeholder{color:var(--sub);}
.search-ic{position:absolute;left:9px;top:50%;transform:translateY(-50%);font-size:13px;color:var(--sub);pointer-events:none;}
.sort-sel{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:5px 10px;font-size:12px;color:var(--sub2);font-family:'Plus Jakarta Sans',sans-serif;outline:none;cursor:pointer;transition:border-color .18s;}
.sort-sel:hover{border-color:var(--border2);}
.sort-sel option{background:#0c1525;color:#f0f4ff;}
.empty-state{grid-column:1/-1;text-align:center;padding:3rem 1rem;}
.empty-icon{font-size:36px;margin-bottom:.8rem;}
.empty-title{font-size:14px;font-weight:600;color:var(--sub2);margin-bottom:4px;}
.empty-sub{font-size:12px;color:var(--sub);}
@media(max-width:850px){.stats-row{grid-template-columns:repeat(2,1fr);}}

/* ── TOAST ── */
.toast{position:fixed;bottom:24px;right:24px;z-index:9999;background:linear-gradient(145deg,var(--bg3),var(--bg2));border:1px solid var(--border2);border-radius:14px;padding:1.1rem 1.4rem;box-shadow:0 12px 40px rgba(0,0,0,.4);display:flex;align-items:center;gap:12px;animation:toastIn .4s ease;max-width:380px;}
@keyframes toastIn{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:translateX(0)}}
.toast-icon{font-size:24px;}
.toast-body{flex:1;}
.toast-title{font-size:14px;font-weight:700;margin-bottom:2px;}
.toast-msg{font-size:12px;color:var(--sub2);}
.toast-close{background:none;border:none;color:var(--sub);cursor:pointer;font-size:16px;padding:4px;}

/* ── MOBILE ── */
.mobile-toggle{display:none;align-items:center;justify-content:center;width:36px;height:36px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);font-size:18px;cursor:pointer;flex-shrink:0;}
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(4px);z-index:19;}

@media(max-width:850px){
  .mobile-toggle{display:flex;}
  .sidebar{position:fixed;left:0;top:0;transform:translateX(-100%);transition:transform .35s cubic-bezier(.4,0,.2,1);z-index:20;box-shadow:4px 0 30px rgba(0,0,0,.5);}
  .sidebar.open{transform:translateX(0);}
  .sidebar-overlay.open{display:block;}
  .main-wrap{width:100%;}
  .topbar{padding:1rem 1.2rem;}
  .page{padding:1.2rem 1.4rem;}
  .t-pill{display:none;}
  .sig-grid{grid-template-columns:1fr;}
}
@media(max-width:600px){
  .page{padding:1rem;}
  .flt{gap:6px;}
  .fb{padding:4px 9px;font-size:11px;}
  .sig-meta{grid-template-columns:1fr 1fr;}
}
.nav-affiliate-wrap { position: relative; display: inline-block; }
.nav-earn-badge { position: absolute; top: -9px; right: -28px; font-size: 8px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #34d399; background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.35); border-radius: 4px; padding: 2px 6px; line-height: 1.5; transform: rotate(12deg); pointer-events: none; white-space: nowrap; }
</style>



</head>
<body>
<script>
(function(){
  var S="https://sjntsmzbiqvtstvofcnx.supabase.co";
  var K="sb_publishable_n0q0FsM9hZARXxKKIDprFw_O6GJfRAg";
  var CK="tren_session";
  var CHECKOUT_URL="https://trenai.vercel.app/checkout-premium";
  var PRICING_URL="https://trenai.vercel.app/pricing";
  function E(){try{var s=JSON.parse(localStorage.getItem(CK)||"null");return s&&s.user&&s.user.email?s.user.email:null}catch(e){return null}}
  async function A(){
    var e=E();if(!e)return false;
    try{var x=JSON.parse(localStorage.getItem("tren_sub")||"null");if(x&&x.status==="active"&&x.plan==="premium")return true;var y=JSON.parse(localStorage.getItem("tren_trenbot_sub")||"null");if(y&&y.status==="active"&&y.plan==="trenbot")return true;var z=JSON.parse(localStorage.getItem("tren_autosignals_sub")||"null");if(z&&z.status==="active"&&z.plan==="auto")return true}catch(e){}
    var P=[["premium","premium"],["trenbot","trenbot"],["auto","auto"]];
    for(var i=0;i<P.length;i++){try{var r=await fetch(S+"/rest/v1/subscribers?email=eq."+encodeURIComponent(e.toLowerCase().trim())+"&plan=eq."+P[i][1]+"&status=eq.active&select=*",{headers:{"apikey":K,"Authorization":"Bearer "+K}});var w=await r.json();if(w&&w.length>0&&w[0].status==="active")return true}catch(e){}}
    return false;
  }
  function W(){
    if(document.getElementById("__pw"))return;
    var st=document.createElement("style");
    st.id="__pw_st";
    st.textContent="@keyframes pwG{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}@keyframes pwFd{from{opacity:0;transform:translateY(10px) scale(.97)}to{opacity:1;transform:none}}@keyframes pwPl{0%,100%{box-shadow:0 0 0 0 rgba(16,185,129,.5)}70%{box-shadow:0 0 0 8px rgba(16,185,129,0)}}@keyframes pwSh{from{transform:translateX(-250%)}to{transform:translateX(500%)}}#__pw .pw-c{animation:pwFd .35s cubic-bezier(.16,1,.3,1) forwards}#__pw .pw-g{background:linear-gradient(135deg,#1d4ed8,#7c3aed,#06b6d4,#1d4ed8);background-size:300% 300%;animation:pwG 6s ease infinite}#__pw .pw-dot{width:7px;height:7px;border-radius:50%;background:#10b981;animation:pwPl 2s ease infinite;display:inline-block;flex-shrink:0}#__pw .pw-b{display:block;width:100%;padding:15px 24px;border-radius:13px;background:linear-gradient(90deg,#1d4ed8,#3b82f6);color:#fff;font-size:14px;font-weight:700;text-decoration:none;text-align:center;box-sizing:border-box;position:relative;overflow:hidden;transition:transform .15s,box-shadow .15s}#__pw .pw-b:hover{transform:translateY(-2px);box-shadow:0 14px 40px rgba(59,130,246,.45)}#__pw .pw-b::after{content:'';position:absolute;top:0;left:0;width:30%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent);transform:translateX(-250%);animation:pwSh 3.5s ease 2s infinite}#__pw .pw-f{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:16px 10px;text-align:center;transition:border-color .2s,background .2s}#__pw .pw-f:hover{background:rgba(37,99,235,.08);border-color:rgba(37,99,235,.3)}";
    document.head.appendChild(st);
    var d=document.createElement("div");
    d.id="__pw";
    d.innerHTML='<div style="position:fixed;inset:0;z-index:99999;display:flex;align-items:center;justify-content:center;font-family:Plus Jakarta Sans,sans-serif;padding:20px;box-sizing:border-box;"><div style="position:fixed;inset:0;background:rgba(2,6,14,.92);backdrop-filter:blur(32px);-webkit-backdrop-filter:blur(32px);"></div><div class="pw-c" style="position:relative;z-index:1;width:100%;max-width:476px;"><div class="pw-g" style="position:absolute;inset:-1.5px;border-radius:26px;opacity:.75;"></div><div style="position:relative;background:#060D1A;border-radius:24px;padding:40px 36px 32px;overflow:hidden;"><div style="position:absolute;inset:0;background-image:linear-gradient(rgba(37,99,235,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(37,99,235,.05) 1px,transparent 1px);background-size:32px 32px;pointer-events:none;"></div><div style="position:relative;display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:22px;"><div class="pw-dot"></div><span style="font-size:10.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#3b82f6;">Tren Premium</span></div><h2 style="position:relative;font-size:26px;font-weight:800;color:#f0f4ff;margin:0 0 10px;letter-spacing:-.5px;line-height:1.25;text-align:center;">Your edge is locked.<br><span style="background:linear-gradient(90deg,#60a5fa,#818cf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Unlock it today.</span></h2><p style="position:relative;font-size:13px;color:rgba(240,244,255,.45);line-height:1.65;text-align:center;margin:0 0 24px;">Real-time NQ signals, AI analysis, and automated bots &mdash; built for serious futures traders.</p><div style="position:relative;display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:20px;"><div class="pw-f"><div style="font-size:20px;margin-bottom:6px;">&#128225;</div><div style="font-size:11px;font-weight:700;color:#f0f4ff;margin-bottom:3px;">Live Signals</div><div style="font-size:10px;color:rgba(240,244,255,.38);line-height:1.4;">Real-time NQ alerts</div></div><div class="pw-f"><div style="font-size:20px;margin-bottom:6px;">&#129302;</div><div style="font-size:11px;font-weight:700;color:#f0f4ff;margin-bottom:3px;">AI Analysis</div><div style="font-size:10px;color:rgba(240,244,255,.38);line-height:1.4;">Daily market edge</div></div><div class="pw-f"><div style="font-size:20px;margin-bottom:6px;">&#9889;</div><div style="font-size:11px;font-weight:700;color:#f0f4ff;margin-bottom:3px;">Auto Trading</div><div style="font-size:10px;color:rgba(240,244,255,.38);line-height:1.4;">Set-and-forget bots</div></div></div><div style="position:relative;margin-bottom:24px;"><div style="display:flex;flex-direction:column;gap:6px;filter:blur(3.5px);pointer-events:none;user-select:none;"><div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:10px;"><span style="width:6px;height:6px;border-radius:50%;background:#10b981;flex-shrink:0;"></span><span style="font-size:11px;font-weight:700;color:#10b981;">LONG</span><span style="font-size:11px;color:rgba(240,244,255,.6);">NQ Future @ 21,847.50</span><span style="margin-left:auto;font-size:11px;font-weight:700;color:#10b981;">+12.5 pts</span></div><div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:10px;"><span style="width:6px;height:6px;border-radius:50%;background:#ef4444;flex-shrink:0;"></span><span style="font-size:11px;font-weight:700;color:#ef4444;">SHORT</span><span style="font-size:11px;color:rgba(240,244,255,.6);">NQ Future @ 21,903.00</span><span style="margin-left:auto;font-size:11px;font-weight:700;color:#10b981;">+8.0 pts</span></div></div><div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;border-radius:10px;background:rgba(4,8,16,.3);"><div style="display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:100px;padding:8px 16px;"><svg width="12" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(240,244,255,.55)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><span style="font-size:11.5px;font-weight:600;color:rgba(240,244,255,.55);">Signals locked</span></div></div></div><a href="'+CHECKOUT_URL+'" class="pw-b">Start Free Trial &#8594;</a><div style="display:flex;align-items:center;justify-content:center;gap:14px;margin-top:14px;"><a href="'+PRICING_URL+'" style="font-size:12px;color:#3b82f6;text-decoration:none;font-weight:600;">View all plans</a><span style="color:rgba(240,244,255,.15);">&#183;</span><a href="https://trenai.vercel.app/login-page" style="font-size:12px;color:rgba(240,244,255,.3);text-decoration:none;">Sign in</a></div></div></div></div>';
    document.body.appendChild(d);document.body.style.overflow="hidden";
  }
  (async function(){var h=await A();if(!h)W()})();
})();
</script>



<div class="shell">

  <div class="sidebar-overlay" id="sb-overlay" onclick="closeSidebar()"></div>

    <!-- SIDEBAR -->
  <nav class="sidebar" id="sidebar">
    <a class="s-logo" href="https://trenai.vercel.app" style="text-decoration:none;color:inherit;">
      <span class="s-logo-dot"></span>
      tren<span>.</span>
    </a>

    <div class="s-nav">
      <div class="s-section-label">Trading</div>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/live-signals')">
        <span class="s-ic"><span class="live-dot-nav"></span></span><span>Live Signals</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/overview')">
        <span class="s-ic">📊</span><span>Overview</span>
      </a>
      <a class="s-item on" onclick="navTo('https://trenai.vercel.app/signals')">
        <span class="s-ic">⚡</span><span>Recent Trades</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/journal')">
        <span class="s-ic">📓</span><span>Journal</span>
      </a>

      <div class="s-divider"></div>
      <div class="s-section-label">Tools</div>
      <a class="s-item ai-item" onclick="navTo('https://trenai.vercel.app/ai-analysis')">
        <span class="s-ic">✨</span><span>AI Analysis</span>
        <span class="s-beta">BETA</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/trenbot')">
        <span class="s-ic">🤖</span><span>TrenBot</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/autosignals')">
        <span class="s-ic">⚡</span><span>AutoSignals</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/indicator')">
        <span class="s-ic">📈</span><span>Indicator</span>
      </a>

      <div class="s-divider"></div>
      <div class="s-section-label">Misc</div>
      <a class="s-item gold" onclick="navTo('https://trenai.vercel.app/upgrade')">
        <span class="s-ic">👑</span><span>Upgrade</span>
        <span class="s-badge">PRO</span>
      </a>
      <a class="s-item" onclick="navTo('https://trenai.vercel.app/settings')">
        <span class="s-ic">⚙️</span><span>Settings</span>
      </a>
    </div>

    <div class="s-bot">
      <a class="u-row" onclick="navTo('https://trenai.vercel.app/settings')">
        <div class="u-av" id="s-av">T</div>
        <div class="u-info">
          <div class="u-name" id="s-nm">Trader</div>
          <div class="u-email" id="s-email-display">—</div>
          <span class="sub-status-badge trial" id="sidebar-plan-badge">⚡ Trial</span>
        </div>
      </a>
      <div class="s-logout" onclick="doLogout()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sign out
      </div>
    </div>
  </nav>

  <!-- MAIN -->
  <div class="main-wrap">

    <!-- TOPBAR -->
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;">
        <button class="mobile-toggle" onclick="toggleSidebar()">☰</button>
        <div class="tb-title">Recent Trades</div>
      </div>
      <div class="tb-right">
        <div class="t-pill" id="trial-pill">⏱ <span id="pill-days">7</span> days left in trial</div>
        <div class="nb">🔔</div>
        <div class="prof-wrap">
          <div class="prof-av" id="prof-av-btn" onclick="toggleProfileMenu()">T</div>
          <div class="prof-menu" id="prof-menu">
            <div class="prof-menu-header">
              <div class="prof-menu-name" id="prof-menu-name">Trader</div>
              <div class="prof-menu-email" id="prof-menu-email">—</div>
            </div>
            <a class="prof-menu-item" onclick="navTo('https://trenai.vercel.app/settings')">👤 Profile settings</a>
            <div class="prof-menu-item danger" onclick="doLogout()">→ Sign out</div>
          </div>
        </div>
      </div>
    </div>

    <!-- PAGE -->
    <div class="page">

      <!-- STATS STRIP -->
      <div class="stats-row" id="stats-row">
        <div class="stat-card sc-total">
          <div class="stat-label">Total Trades</div>
          <div class="stat-val" id="stat-total">—</div>
          <div class="stat-sub" id="stat-active-sub">— active</div>
        </div>
        <div class="stat-card sc-wr">
          <div class="stat-label">Win Rate</div>
          <div class="stat-val" id="stat-wr" style="color:var(--green)">—</div>
          <div class="stat-sub" id="stat-wr-sub">— wins / — losses</div>
        </div>
        <div class="stat-card sc-pnl">
          <div class="stat-label">Total P&L</div>
          <div class="stat-val" id="stat-pnl">—</div>
          <div class="stat-sub" id="stat-pnl-sub">closed trades only</div>
        </div>
        <div class="stat-card sc-ticks">
          <div class="stat-label">Avg Ticks</div>
          <div class="stat-val" id="stat-ticks" style="color:#a78bfa">—</div>
          <div class="stat-sub" id="stat-best-sub">best: —</div>
        </div>
      </div>

      <!-- FILTER + SEARCH + SORT -->
      <div class="flt-top">
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
          <span style="font-size:12px;color:var(--sub);font-weight:500;">Filter:</span>
          <button class="fb on" onclick="flt('all',this)">All</button>
          <button class="fb" onclick="flt('long',this)">Long</button>
          <button class="fb" onclick="flt('short',this)">Short</button>
          <button class="fb" onclick="flt('active',this)">Active</button>
          <button class="fb" onclick="flt('win',this)">Wins</button>
          <button class="fb" onclick="flt('loss',this)">Losses</button>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
          <div class="search-wrap">
            <span class="search-ic">📅</span>
            <input class="search-input" id="sig-search" type="date" oninput="renderAllSigs()" style="padding-left:30px;color-scheme:dark;">
          </div>
          <select class="sort-sel" id="sig-sort" onchange="renderAllSigs()">
            <option value="date">Latest first</option>
            <option value="pnl_desc">P&L high → low</option>
            <option value="pnl_asc">P&L low → high</option>
            <option value="ticks">Most ticks</option>
          </select>
        </div>
      </div>

      <div class="sig-grid" id="all-sigs">
        <div class="skel" style="height:120px;border-radius:13px;"></div>
        <div class="skel" style="height:120px;border-radius:13px;"></div>
        <div class="skel" style="height:120px;border-radius:13px;"></div>
        <div class="skel" style="height:120px;border-radius:13px;"></div>
      </div>
    </div>

  </div>
</div>

<script>
// ── SESSION RECOVERY (runs before anything else) ──────────────────
(function(){
  try{
    const p=new URLSearchParams(window.location.search);
    const t=p.get('_t');
    if(t){
      const existing=localStorage.getItem('tren_session');
      if(!existing){
        const decoded=JSON.parse(atob(decodeURIComponent(t)));
        localStorage.setItem('tren_session',JSON.stringify(decoded));
      }
      window.history.replaceState({},'',window.location.pathname);
    }
  }catch(e){}
})();

// ── CORE ──────────────────────────────────────────────────────────
const SUPABASE_AUTH_URL='https://sjntsmzbiqvtstvofcnx.supabase.co';
const SUPABASE_AUTH_KEY='sb_publishable_n0q0FsM9hZARXxKKIDprFw_O6GJfRAg';
const SUPABASE_URL='https://rjzteejovzmytfeupeaa.supabase.co';
const SUPABASE_KEY='sb_publishable_p0W2wgXC1zc73-50mSx2ew_OBOCMSXJ';
const SESSION_KEY='tren_session';

// ── NAV WITH SESSION PASSTHROUGH + DEBOUNCE ──────────────────────
let _navLock=false;
function navTo(url){
  if(_navLock)return;
  _navLock=true;
  setTimeout(()=>{_navLock=false;},800);
  try{
    const s=localStorage.getItem(SESSION_KEY);
    if(s){
      const encoded=encodeURIComponent(btoa(s));
      url+=(url.includes('?')?'&':'?')+'_t='+encoded;
    }
  }catch(e){}
  window.location.href=url;
}

let _session=window.__trenSession||(()=>{try{const r=localStorage.getItem(SESSION_KEY);return r?JSON.parse(r):null;}catch{return null;}})();
if(!(_session&&_session.access_token)){window.location.href='https://trenai.vercel.app/login-page';}

let _subData=null,_autoSubData=null,_autoSignalsSubData=null;
try{_subData=JSON.parse(localStorage.getItem('tren_sub')||'null');}catch(e){}
try{_autoSubData=JSON.parse(localStorage.getItem('tren_trenbot_sub')||'null');}catch(e){}
try{_autoSignalsSubData=JSON.parse(localStorage.getItem('tren_autosignals_sub')||'null');}catch(e){}

function getSessionEmail(){return _session&&_session.user&&_session.user.email?_session.user.email:'—';}
function getSessionFullName(){if(_session&&_session.user){const m=_session.user.user_metadata||{};if(m.full_name)return m.full_name;if(m.name)return m.name;if(_session.user.email)return _session.user.email.split('@')[0].replace(/[._]/g,' ').replace(/\b\w/g,c=>c.toUpperCase());}return'Trader';}
function getPrefs(){return JSON.parse(localStorage.getItem('tren_prefs')||'{}');}
function getUserDisplayName(){const e=getSessionEmail(),p=getPrefs(),u=p.display_names||{};return u[e]||getSessionFullName();}
function escHtml(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function fmtNum(n,d){return Number(n).toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d});}
function fmtDate(iso){const d=new Date(iso),now=new Date();const dm=Math.floor((now-d)/60000);if(dm<60)return dm<=1?'just now':`${dm}m ago`;const dh=Math.floor(dm/60);if(dh<24)return`${dh}h ago`;return d.toLocaleDateString('en-GB',{day:'numeric',month:'short'});}
async function sbFetch(path){const res=await fetch(`${SUPABASE_URL}/rest/v1/${path}`,{headers:{'apikey':SUPABASE_KEY}});if(!res.ok)throw new Error(res.status);return res.json();}
function showToast(icon,title,msg){const ex=document.querySelector('.toast');if(ex)ex.remove();const t=document.createElement('div');t.className='toast';t.innerHTML=`<div class="toast-icon">${icon}</div><div class="toast-body"><div class="toast-title">${escHtml(title)}</div><div class="toast-msg">${escHtml(msg)}</div></div><button class="toast-close" onclick="this.parentElement.remove()">✕</button>`;document.body.appendChild(t);setTimeout(()=>{if(t.parentElement)t.remove();},5000);}

async function doLogout(){
  const tok=_session?_session.access_token:'';
  localStorage.removeItem(SESSION_KEY);
  ['tren_sub','tren_prefs','tren_auto_sub','tren_autosignals_sub','tren_trenbot_sub'].forEach(k=>localStorage.removeItem(k));
  try{fetch(`${SUPABASE_AUTH_URL}/auth/v1/logout`,{method:'POST',headers:{'apikey':SUPABASE_AUTH_KEY,'Authorization':'Bearer '+tok}}).catch(()=>{});}catch(e){}
  window.location.href='https://trenai.vercel.app/login-page';
}

function initUserInfo(){
  const name=getUserDisplayName(),email=getSessionEmail(),init=name.charAt(0).toUpperCase();
  ['s-nm','prof-menu-name'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=name;});
  ['s-av','prof-av-btn'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=init;});
  const se=document.getElementById('s-email-display');if(se)se.textContent=email;
  const pe=document.getElementById('prof-menu-email');if(pe)pe.textContent=email;
}

function initSubUI(){
  const hasTB=_autoSubData?.status==='active'&&_autoSubData?.plan==='trenbot';
  const hasAS=_autoSignalsSubData?.status==='active'&&_autoSignalsSubData?.plan==='auto';
  const hasP=_subData?.status&&_subData.status!=='inactive'&&_subData.status!=='cancelled';
  const tc=document.getElementById('trial-card');
  const tp=document.getElementById('trial-pill');
  const sb=document.getElementById('sidebar-plan-badge');
  if(hasTB||hasAS||hasP){
    if(tc)tc.style.display='none';
    let lbl='⚡ Premium',cls='premium';
    if(hasTB){lbl='⚡ TrenBot';cls='automated';}
    else if(hasAS){lbl='⚡ AutoSignals';cls='autosignals';}
    if(tp){tp.textContent=lbl+' Active';tp.className='t-pill '+cls;}
    if(sb){sb.textContent=lbl;sb.className='sub-status-badge '+cls;}
  }
}

function toggleProfileMenu(){
  const m=document.getElementById('prof-menu'),b=document.getElementById('prof-av-btn');
  const o=m.classList.contains('open');
  m.classList.toggle('open',!o);b.classList.toggle('open',!o);
}
document.addEventListener('click',e=>{
  const pw=document.querySelector('.prof-wrap');
  if(pw&&!pw.contains(e.target)){document.getElementById('prof-menu').classList.remove('open');document.getElementById('prof-av-btn').classList.remove('open');}
  const sb=document.getElementById('sidebar');
  if(window.innerWidth<=850&&sb.classList.contains('open')&&!sb.contains(e.target)&&!document.querySelector('.mobile-toggle').contains(e.target)){closeSidebar();}
});
function toggleSidebar(){document.getElementById('sidebar').classList.toggle('open');document.getElementById('sb-overlay').classList.toggle('open');}
function closeSidebar(){document.getElementById('sidebar').classList.remove('open');document.getElementById('sb-overlay').classList.remove('open');}

// ── SIGNALS LOGIC ─────────────────────────────────────────────────
let allSignalsData=[],currentFilter='all';

function updateStats(data){
  const closed=data.filter(t=>t.exit&&t.exit!==null);
  const active=data.filter(t=>!t.exit||t.exit===null);
  const wins=closed.filter(t=>parseFloat(t.pnl||0)>0);
  const losses=closed.filter(t=>parseFloat(t.pnl||0)<0);
  const totalPnl=closed.reduce((s,t)=>s+parseFloat(t.pnl||0),0);
  const pnlUp=totalPnl>=0;
  const wr=closed.length?Math.round((wins.length/closed.length)*100):0;
  const ticks=closed.filter(t=>t.ticks).map(t=>parseFloat(t.ticks));
  const avgTicks=ticks.length?Math.round(ticks.reduce((a,b)=>a+b,0)/ticks.length):0;
  const bestTick=ticks.length?Math.max(...ticks):0;
  const el=id=>document.getElementById(id);
  el('stat-total').textContent=data.length;
  el('stat-active-sub').textContent=`${active.length} active · ${closed.length} closed`;
  el('stat-wr').textContent=closed.length?wr+'%':'—';
  el('stat-wr').style.color=wr>=50?'var(--green)':'var(--red)';
  el('stat-wr-sub').textContent=`${wins.length} wins / ${losses.length} losses`;
  el('stat-pnl').textContent=closed.length?(pnlUp?'+':'')+totalPnl.toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0,style:'currency',currency:'USD'}):'—';
  el('stat-pnl').style.color=pnlUp?'var(--green)':'var(--red)';
  el('stat-ticks').textContent=avgTicks||'—';
  el('stat-best-sub').textContent=`best: ${bestTick||'—'} ticks`;
}

function buildSignalCard(t){
  const isActive=!t.exit||t.exit===null;
  const pnl=parseFloat(t.pnl||0);const win=pnl>=0;
  const dir=(t.direction||'').toLowerCase();const isLong=dir==='long';
  const pnlStr=isActive
    ?'<span class="sig-st ac">● Live</span>'
    :`<span class="sig-pnl-badge ${win?'pos':'neg'}">${win?'+':'-'}$${Math.abs(pnl).toLocaleString('en-US',{maximumFractionDigits:0})}</span>`;
  const statusLabel=isActive?'':win?'✓ TP Hit':'✗ SL Hit';
  const statusCls=win?'ht':'ls';
  return`<div class="sig-card ${isActive?'':win?'win-border':'loss-border'}">
    <div class="sig-top">
      <div style="display:flex;align-items:center;gap:8px;">
        <div class="sig-pair">${escHtml(t.market||'—')}</div>
        <div class="sig-dir ${isLong?'lng':'sht'}">${dir.toUpperCase()}</div>
      </div>
      ${pnlStr}
    </div>
    <div class="sig-meta">
      <div class="sig-f"><label>Entry</label><p>${t.entry?fmtNum(t.entry,2):'—'}</p></div>
      <div class="sig-f"><label>Exit</label><p class="${win&&!isActive?'g':!win&&!isActive?'r':''}">${t.exit?fmtNum(t.exit,2):'—'}</p></div>
      <div class="sig-f"><label>Ticks</label><p style="color:${t.ticks&&parseFloat(t.ticks)>0?'var(--green)':t.ticks&&parseFloat(t.ticks)<0?'var(--red)':'inherit'}">${t.ticks||'—'}</p></div>
    </div>
    <div class="sig-bw"><div class="sig-b" style="width:${isActive?40:100}%;background:${isActive?'var(--al)':win?'var(--green)':'var(--red)'};"></div></div>
    <div class="sig-ft">
      <div class="sig-tm">${fmtDate(t.executed_at)}</div>
      ${!isActive?`<div class="sig-st ${statusCls}">${statusLabel}</div>`:''}
    </div>
  </div>`;
}

function renderAllSigs(f){
  if(f)currentFilter=f;
  const el=document.getElementById('all-sigs');
  const search=(document.getElementById('sig-search')?.value||'').toLowerCase().trim();
  const sort=document.getElementById('sig-sort')?.value||'date';
  let filtered=[...allSignalsData];
  if(currentFilter==='long')   filtered=filtered.filter(t=>(t.direction||'').toLowerCase()==='long');
  if(currentFilter==='short')  filtered=filtered.filter(t=>(t.direction||'').toLowerCase()==='short');
  if(currentFilter==='active') filtered=filtered.filter(t=>!t.exit);
  if(currentFilter==='win')    filtered=filtered.filter(t=>parseFloat(t.pnl||0)>0);
  if(currentFilter==='loss')   filtered=filtered.filter(t=>parseFloat(t.pnl||0)<0);
  if(search) filtered=filtered.filter(t=>t.executed_at&&t.executed_at.slice(0,10)===search);
  if(sort==='pnl_desc') filtered.sort((a,b)=>parseFloat(b.pnl||0)-parseFloat(a.pnl||0));
  else if(sort==='pnl_asc') filtered.sort((a,b)=>parseFloat(a.pnl||0)-parseFloat(b.pnl||0));
  else if(sort==='ticks') filtered.sort((a,b)=>parseFloat(b.ticks||0)-parseFloat(a.ticks||0));
  else filtered.sort((a,b)=>new Date(b.executed_at)-new Date(a.executed_at));
  if(!filtered.length){
    el.innerHTML=`<div class="empty-state"><div class="empty-icon">📭</div><div class="empty-title">No trades found</div><div class="empty-sub">${search?'No trades on this date.':'No signals match this filter.'}</div></div>`;
    return;
  }
  el.innerHTML=filtered.map(buildSignalCard).join('');
}

async function loadAllSignals(){
  const el=document.getElementById('all-sigs');
  try{
    const data=await sbFetch('trades?order=executed_at.desc&limit=100');
    allSignalsData=data;
    updateStats(data);
    renderAllSigs(currentFilter);
  }catch(e){
    el.innerHTML=`<div class="empty-state"><div class="empty-icon">⚠️</div><div class="empty-title">Could not load signals</div><div class="empty-sub">Retrying in 5 seconds…</div></div>`;
    setTimeout(loadAllSignals,5000);
  }
}

function flt(f,btn){
  document.querySelectorAll('.fb').forEach(b=>b.classList.remove('on'));
  if(btn)btn.classList.add('on');
  renderAllSigs(f);
}

// ── INIT ──────────────────────────────────────────────────────────
initUserInfo();
initSubUI();
loadAllSignals();
setInterval(loadAllSignals,30000);
</script>
<script>
  function goToDashboard(e) {
    e.preventDefault();
    if (localStorage.getItem('tren_session')) {
      window.location.href = '/overview';
    } else {
      window.location.href = '/login-page';
    }
  }
</script>
</body>
</html>
